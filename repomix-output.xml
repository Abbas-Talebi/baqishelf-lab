              borderRadius: 12,

              barThickness: 34,
            },
          ],
        },

        options: {
          indexAxis: "y",

          responsive: true,

          maintainAspectRatio: false,

          plugins: {
            legend: {
              display: false,
            },

            tooltip: {
              callbacks: {
                label: (context) =>
                  `${context.raw} اثر`,
