          scales: {
            x: {
              beginAtZero: true,

              grid: {
                display: false,
              },

              border: {
                display: false,
              },
            },

            y: {
              grid: {
                display: false,
              },

              border: {
                display: false,
              },
            },
          },
        },
      }
    );

    return () => {
      chart.destroy();
