---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import MovieCard from "../components/MovieCard.astro";
import MovieTable from "../components/MovieTable.astro";
import SearchBar from "../components/SearchBar.astro";

const base = import.meta.env.BASE_URL;

const movies = await getCollection("movies");

const sortedMovies = [...movies].sort(
  (a, b) => b.data.personal_rating - a.data.personal_rating
);

const view = Astro.url.searchParams.get("view") ?? "card";
---

<BaseLayout title="فیلم‌ها">
  <h1>فیلم‌ها</h1>

  <SearchBar placeholder="جستجوی فیلم..." />

  <div class="view-switch">
    <a href={`${base}movies`}>
      نمای کارت
    </a>

    <a href={`${base}movies/table`}>
      نمای جدول
    </a>
  </div>

  <p>تعداد فیلم‌ها: {movies.length}</p>

  {
    view === "table" ? (
      <MovieTable movies={movies} />
    ) : (
      <div id="movies-list">
        {sortedMovies.map((movie) => (
          <MovieCard movie={movie} />
        ))}
      </div>
    )
  }
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const searchInput =
      document.getElementById("media-search");

    const moviesContainer =
      document.getElementById("movies-list");

    if (!searchInput || !moviesContainer)
      return;

    const getCards = () =>
      [
        ...document.querySelectorAll(
          "#movies-list .card"
        ),
      ];

    const applyFilter = () => {
      const query =
        searchInput.value
          .trim()
          .toLowerCase();

      getCards().forEach((card) => {
        const title =
          card.dataset.title?.toLowerCase() ??
          "";

        if (
          query &&
          !title.includes(query)
        ) {
          card.style.display = "none";
        } else {
          card.style.display = "";
        }
      });
    };

    searchInput.addEventListener(
      "input",
      applyFilter
    );

    applyFilter();
  });
</script>

<style>
  .view-switch {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .view-switch a {
    border: 1px solid #333;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    text-decoration: none;
  }

  #movies-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
</file>

