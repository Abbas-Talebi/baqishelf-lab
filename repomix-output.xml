---
import Rating from "./Rating.astro";

const { series } = Astro.props;

const base = import.meta.env.BASE_URL;

const statusMap = {
  watched: "✓ تماشا شده",
  watching: "🎬 در حال تماشا",
  planned: "📋 برنامه تماشا",
  dropped: "✕ رها شده",
};
---

<table class="item-table">
  <thead>
    <tr>
      <th>کاور</th>
      <th data-sort="string">عنوان ↕</th>
      <th data-sort="number">امتیاز ↕</th>
      <th data-sort="number">سال ↕</th>
      <th data-sort="string">ژانر ↕</th>
      <th data-sort="string">وضعیت ↕</th>
      <th data-sort="date">تاریخ تماشا ↕</th>
    </tr>
  </thead>

  <tbody>
    {
      series.map((item) => (
        <tr>

          <td>
            {
              item.data.cover && (
                <img
                  src={`${base}covers/${item.data.cover}`}
                  alt={item.data.title}
                  class="cover"
                />
              )
            }
          </td>

          <td data-value={item.data.title}>
            <a href={`${base}series/${item.id}`}>
              {item.data.title}
            </a>
          </td>

          <td data-value={item.data.personal_rating}>
            <Rating value={item.data.personal_rating} />
          </td>

          <td data-value={item.data.year}>
            {item.data.year}
          </td>

          <td data-value={item.data.genres?.join(", ") ?? ""}>
            {item.data.genres?.join("، ")}
          </td>

          <td data-value={item.data.status ?? ""}>
            {statusMap[item.data.status] ?? item.data.status}
          </td>

          <td data-value={item.data.date_watched?.getTime() ?? 0}>
            {item.data.date_watched?.toLocaleDateString("fa-IR")}
          </td>

        </tr>
      ))
    }
  </tbody>
</table>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const table = document.querySelector(".item-table");
    if (!table) return;

    const headers = table.querySelectorAll("th[data-sort]");

    headers.forEach((header) => {
      let ascending = true;
      header.style.cursor = "pointer";

      header.addEventListener("click", () => {
        const tbody = table.querySelector("tbody");
        if (!tbody) return;

        const rows = Array.from(tbody.querySelectorAll("tr"));

        const columnIndex = header.cellIndex;
        const sortType = header.dataset.sort;

        rows.sort((a, b) => {
          const aCell = a.children[columnIndex];
          const bCell = b.children[columnIndex];

          let aVal = aCell?.dataset?.value ?? "";
          let bVal = bCell?.dataset?.value ?? "";

          if (sortType === "number" || sortType === "date") {
            aVal = Number(aVal);
            bVal = Number(bVal);

            return ascending
              ? aVal - bVal
              : bVal - aVal;
          }

          return ascending
            ? String(aVal).localeCompare(String(bVal))
            : String(bVal).localeCompare(String(aVal));
        });

        ascending = !ascending;
        tbody.replaceChildren(...rows);
      });
    });
  });
</script>

<style>
.item-table {
  width: 100%;
  border-collapse: collapse;
}

.item-table th,
.item-table td {
  padding: 0.75rem;
  text-align: center;
  vertical-align: middle;
  border-bottom: 1px solid #2a2a2a;
}

.cover {
  width: 60px;
  height: 90px;
  object-fit: cover;
  border-radius: 6px;
  display: block;
  margin: 0 auto;
}

.item-table td a {
  text-decoration: none;
}
</style>
