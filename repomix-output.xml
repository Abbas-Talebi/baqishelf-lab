    ...games.flatMap((item) => item.data.genres ?? []),
    ...movies.flatMap((item) => item.data.genres ?? []),
    ...books.flatMap((item) => item.data.genres ?? []),
    ...series.flatMap((item) => item.data.genres ?? []),
    ...music.flatMap((item) => item.data.genres ?? []),
  ]),
].sort();
---

<BaseLayout title="ژانرها">

<h1>ژانرها</h1>

<div class="genres-grid">

  {
    genres.map((genre) => (
