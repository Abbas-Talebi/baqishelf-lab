    max-width: 200px;
    height: 8px;
    border-radius: 999px;
    background: #222;
    overflow: hidden;
    margin: 0.3rem 0;
  }
  .progress-fill {
    height: 100%;
    background: #8b5cf6;
  }
  .rating-details {
    margin-top: 0.5rem;
    padding: 0.5rem;
    background: #0a0a0a;
    border-radius: 12px;
  }
  .rating-details summary {
    cursor: pointer;
    font-weight: bold;
    color: #aaa;
  }
  .rating-details div {
    margin: 0.3rem 0;
  }
  h1 {
    font-size: 2.2rem;
    margin-bottom: 1.5rem;
  }
  h2 {
    font-size: 1.8rem;
    margin: 2rem 0 1rem;
  }
  @media (max-width: 700px) {
    .game-card {
      flex-direction: column;
