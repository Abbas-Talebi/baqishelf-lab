---
import BaseLayout from "../layouts/BaseLayout.astro";
import Rating from "../components/Rating.astro";
import { getCollection } from "astro:content";

const games = await getCollection("games");
const currentYear = new Date().getFullYear();

// فقط بازی‌هایی که در سال جاری تمام شده‌اند
const yearGames = games.filter(
  (game) => game.data.date_finished && game.data.date_finished.getFullYear() === currentYear
);

const totalGames = yearGames.length;
const hasData = totalGames > 0;

// میانگین امتیاز
const averageRating = hasData
  ? (yearGames.reduce((sum, g) => sum + g.data.personal_rating, 0) / totalGames).toFixed(1)
  : 0;

// بازی‌های مورد علاقه در سال جاری
const favoriteGames = yearGames.filter((g) => g.data.tags?.includes("favorite"));

// اولین و آخرین بازی بر اساس تاریخ اتمام
const sortedByDate = [...yearGames].sort(
  (a, b) => a.data.date_finished.getTime() - b.data.date_finished.getTime()
);
const firstGame = sortedByDate[0];
const lastGame = sortedByDate[sortedByDate.length - 1];

// بهترین و بدترین بازی بر اساس امتیاز
const bestGame = [...yearGames].sort((a, b) => b.data.personal_rating - a.data.personal_rating)[0];
const worstGame = [...yearGames].sort((a, b) => a.data.personal_rating - b.data.personal_rating)[0];

// پلتفرم محبوب
const platformCounts = {};
yearGames.forEach((game) => {
  game.data.platforms?.forEach((platform) => {
    platformCounts[platform] = (platformCounts[platform] ?? 0) + 1;
  });
});
const topPlatformEntry = Object.entries(platformCounts).sort((a, b) => b[1] - a[1])[0];
const topPlatform = topPlatformEntry ? { name: topPlatformEntry[0], count: topPlatformEntry[1] } : null;

// ژانر محبوب
const genreCounts = {};
yearGames.forEach((game) => {
  game.data.genres?.forEach((genre) => {
    genreCounts[genre] = (genreCounts[genre] ?? 0) + 1;
  });
});
const topGenreEntry = Object.entries(genreCounts).sort((a, b) => b[1] - a[1])[0];
const topGenre = topGenreEntry ? { name: topGenreEntry[0], count: topGenreEntry[1] } : null;

// فعال‌ترین ماه
const monthCounts = {};
yearGames.forEach((game) => {
  const month = game.data.date_finished.getMonth();
  monthCounts[month] = (monthCounts[month] ?? 0) + 1;
});
const topMonthEntry = Object.entries(monthCounts).sort((a, b) => b[1] - a[1])[0];
const monthNames = [
  "ژانویه", "فوریه", "مارس", "آوریل", "مه", "ژوئن",
  "ژوئیه", "اوت", "سپتامبر", "اکتبر", "نوامبر", "دسامبر"
];
const topMonth = topMonthEntry ? { name: monthNames[Number(topMonthEntry[0])], count: topMonthEntry[1] } : null;

// نرخ تکمیل نسبت به کل بازی‌های موجود
const totalAllGames = games.length;
const completionRate = totalAllGames > 0 ? ((totalGames / totalAllGames) * 100).toFixed(1) : 0;

// نگاشت وضعیت (از کد خطادار)
const statusMap = {
  completed: "✓ تکمیل شده",
  playing: "🎮 در حال تجربه",
  backlog: "📚 در صف",
  paused: "⏸ متوقف شده",
  dropped: "✕ رها شده",
};
---

<BaseLayout title={`Replay ${currentYear}`}>
  <h1>📅 Replay {currentYear}</h1>

  {!hasData ? (
    <p>هیچ بازی‌ای در سال {currentYear} به پایان نرسیده است.</p>
  ) : (
    <>
      <!-- کارت‌های آماری اصلی -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-value">{totalGames}</div>
          <div class="stat-label">بازی تکمیل شده</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{averageRating}</div>
          <div class="stat-label">میانگین امتیاز</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{favoriteGames.length}</div>
          <div class="stat-label">بازی‌های مورد علاقه</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{completionRate}%</div>
          <div class="stat-label">نرخ تکمیل آرشیو</div>
        </div>
      </div>

      <!-- جزئیات بیشتر -->
      <div class="details-grid">
        {firstGame && (
          <div class="detail-item">
            <span class="detail-icon">🎬</span>
            <div>
              <div class="detail-label">اولین بازی سال</div>
              <div class="detail-value">{firstGame.data.title}</div>
            </div>
          </div>
        )}
        {lastGame && (
          <div class="detail-item">
            <span class="detail-icon">🏁</span>
            <div>
              <div class="detail-label">آخرین بازی سال</div>
              <div class="detail-value">{lastGame.data.title}</div>
            </div>
          </div>
        )}
        {bestGame && (
          <div class="detail-item">
            <span class="detail-icon">🏆</span>
            <div>
              <div class="detail-label">بهترین بازی</div>
              <div class="detail-value">
                {bestGame.data.title} ({bestGame.data.personal_rating})
              </div>
            </div>
          </div>
        )}
        {worstGame && (
          <div class="detail-item">
            <span class="detail-icon">💀</span>
            <div>
              <div class="detail-label">ضعیف‌ترین بازی</div>
              <div class="detail-value">
                {worstGame.data.title} ({worstGame.data.personal_rating})
              </div>
            </div>
          </div>
        )}
        {topPlatform && (
          <div class="detail-item">
            <span class="detail-icon">🎮</span>
            <div>
              <div class="detail-label">محبوب‌ترین پلتفرم</div>
              <div class="detail-value">
                {topPlatform.name} ({topPlatform.count} بازی)
              </div>
            </div>
          </div>
        )}
        {topGenre && (
          <div class="detail-item">
            <span class="detail-icon">🔥</span>
            <div>
              <div class="detail-label">محبوب‌ترین ژانر</div>
              <div class="detail-value">
                {topGenre.name} ({topGenre.count} بازی)
              </div>
            </div>
          </div>
        )}
        {topMonth && (
          <div class="detail-item">
            <span class="detail-icon">📅</span>
            <div>
              <div class="detail-label">فعال‌ترین ماه</div>
              <div class="detail-value">
                {topMonth.name} ({topMonth.count} بازی)
              </div>
            </div>
          </div>
        )}
      </div>

      <!-- هایلایت بهترین بازی با کاور -->
      {bestGame && bestGame.data.cover && (
        <div class="highlight-game">
          <img src={`/covers/${bestGame.data.cover}`} alt={bestGame.data.title} />
          <div>
            <h2>⭐ بهترین بازی سال</h2>
            <p>{bestGame.data.title}</p>
            <p>امتیاز: {bestGame.data.personal_rating}</p>
          </div>
        </div>
      )}

      <!-- لیست کامل بازی‌های سال با جزئیات (اضافه شده از کد خطادار) -->
      <h2>📋 همه بازی‌های {currentYear}</h2>
      <div class="games-list">
        {yearGames.map((game) => (
          <div class="game-card">
            {game.data.cover && (
              <img
                src={`/covers/${game.data.cover}`}
                alt={game.data.title}
                class="game-cover-small"
              />
            )}
            <div class="game-card-content">
              <h3>
                <a href={`/games/${game.id}`}>{game.data.title}</a>
              </h3>
              <div class="game-meta">
                <div class="rating-line">
                  <strong>امتیاز من:</strong>
                  <Rating value={game.data.personal_rating} />
                </div>
                <p><strong>سال انتشار:</strong> {game.data.year}</p>
                <p><strong>وضعیت:</strong> {statusMap[game.data.status] ?? game.data.status}</p>
                <p><strong>تاریخ اتمام:</strong> {game.data.date_finished.toLocaleDateString("fa-IR")}</p>
                
                {game.data.completion_percentage !== undefined && (
                  <div>
                    <strong>پیشرفت:</strong>
                    <div class="progress-bar">
                      <div class="progress-fill" style={`width: ${game.data.completion_percentage}%`}></div>
                    </div>
                    <span>{game.data.completion_percentage}%</span>
                  </div>
                )}

                {game.data.achievements_unlocked !== undefined && game.data.achievements_total !== undefined && (
                  <p><strong>اچیومنت‌ها:</strong> {game.data.achievements_unlocked} / {game.data.achievements_total}</p>
                )}

                {game.data.platforms?.length > 0 && (
                  <div class="badges">
                    <strong>پلتفرم‌ها:</strong>
                    {game.data.platforms.map(platform => (
                      <span class="badge">{platform}</span>
                    ))}
                  </div>
                )}

                {game.data.genres?.length > 0 && (
                  <div class="badges">
                    <strong>ژانرها:</strong>
                    {game.data.genres.map(genre => (
                      <span class="badge">{genre}</span>
                    ))}
                  </div>
                )}

                {game.data.tags?.length > 0 && (
                  <div class="badges">
                    <strong>تگ‌ها:</strong>
                    {game.data.tags.map(tag => (
                      <span class="badge">{tag}</span>
                    ))}
                  </div>
                )}

                {game.data.summary && <p class="summary">{game.data.summary}</p>}

                <!-- رتبه‌بندی جزئی (در صورت وجود) -->
                {(game.data.story_rating || game.data.gameplay_rating || game.data.music_rating || game.data.graphics_rating || game.data.technical_rating) && (
                  <details class="rating-details">
                    <summary>جزئیات امتیازدهی</summary>
                    {game.data.story_rating && <div>داستان: <Rating value={game.data.story_rating} /></div>}
                    {game.data.gameplay_rating && <div>گیم‌پلی: <Rating value={game.data.gameplay_rating} /></div>}
                    {game.data.music_rating && <div>موسیقی: <Rating value={game.data.music_rating} /></div>}
                    {game.data.graphics_rating && <div>گرافیک: <Rating value={game.data.graphics_rating} /></div>}
                    {game.data.technical_rating && <div>فنی: <Rating value={game.data.technical_rating} /></div>}
                  </details>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </>
  )}
</BaseLayout>

<style>
  /* استایل‌های قبلی + استایل‌های جدید برای کارت بازی‌ها */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    background: linear-gradient(135deg, #1a1a1a, #0f0f0f);
    border: 1px solid #2a2a2a;
    border-radius: 20px;
    padding: 1.5rem;
    text-align: center;
    transition: transform 0.2s;
  }
  .stat-card:hover {
    transform: translateY(-4px);
    border-color: #3b82f6;
  }
  .stat-value {
    font-size: 2.5rem;
    font-weight: 800;
    color: #8b5cf6;
    margin-bottom: 0.5rem;
  }
  .stat-label {
    font-size: 0.9rem;
    opacity: 0.7;
  }
  .details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .detail-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: #111;
    border: 1px solid #222;
    border-radius: 16px;
    padding: 1rem;
  }
  .detail-icon {
    font-size: 1.8rem;
  }
  .detail-label {
    font-size: 0.75rem;
    opacity: 0.6;
    text-transform: uppercase;
  }
  .detail-value {
    font-weight: 600;
  }
  .highlight-game {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    background: linear-gradient(90deg, #1e1a2f, #0f0f0f);
    border-radius: 24px;
    padding: 1.5rem;
    margin: 2rem 0;
  }
  .highlight-game img {
    width: 140px;
    border-radius: 16px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.4);
  }
  .highlight-game h2 {
    margin: 0 0 0.5rem;
  }
  .games-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .game-card {
    display: flex;
    gap: 1.5rem;
    background: #0f0f0f;
    border: 1px solid #2a2a2a;
    border-radius: 20px;
    padding: 1.5rem;
    transition: transform 0.2s;
  }
  .game-card:hover {
    transform: translateX(4px);
    border-color: #8b5cf6;
  }
  .game-cover-small {
    width: 120px;
    height: auto;
    border-radius: 12px;
    object-fit: cover;
  }
  .game-card-content {
    flex: 1;
  }
  .game-card-content h3 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }
  .game-card-content h3 a {
    color: inherit;
    text-decoration: none;
  }
  .game-card-content h3 a:hover {
    color: #8b5cf6;
  }
  .game-meta p {
    margin: 0.3rem 0;
  }
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0;
  }
  .badge {
    background: #1a1a1a;
    border: 1px solid #333;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    font-size: 0.8rem;
  }
  .summary {
    margin-top: 0.5rem;
    opacity: 0.8;
    font-size: 0.9rem;
  }
  .progress-bar {
