---
const base = import.meta.env.BASE_URL;
---

<header>
  <nav>
    <a href={base} title="آرشیو شخصی باقی">خانه</a>
    <a href={`${base}games`}>بازی‌ها</a>
    <a href={`${base}movies`}>فیلم‌ها</a>
    <a href={`${base}series`}>سریال‌ها</a>
    <a href={`${base}books`}>کتاب‌ها</a>
    <a href={`${base}music`}>موسیقی</a>
    <a href={`${base}stats`}>آمار</a>
    <a href={`${base}timeline`}>خط زمانی</a>
    <a href={`${base}replay`}>بازپخش سالانه</a>
    <a href={`${base}about`} class="about-link">درباره من</a> <!-- این خط اضافه شد -->
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    gap: 1.5rem;
    align-items: center;
    overflow-x: auto;
    white-space: nowrap;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  nav::-webkit-scrollbar {
    display: none;
  }

  nav a {
    text-decoration: none;
    color: inherit;
    font-weight: 500;
    transition: color 0.2s;
  }

  nav a:hover {
    color: #8b5cf6;
  }

  /* استایل ویژه برای لینک درباره من */
  .about-link {
    margin-right: auto; /* هول دادن لینک به سمت چپ منو */
    background: rgba(139, 92, 246, 0.1);
    color: #c4b5fd !important;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(139, 92, 246, 0.3);
  }
  .about-link:hover {
    background: rgba(139, 92, 246, 0.2);
    border-color: #8b5cf6;
  }
</style>