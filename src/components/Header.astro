---
const base = import.meta.env.BASE_URL;
---

<header>
  <nav>
    <a href={base} title="آرشیو شخصی باقی">
      خانه
    </a>

    <a href={`${base}games`}>
      بازی‌ها
    </a>

    <a href={`${base}movies`}>
      فیلم‌ها
    </a>

    <a href={`${base}series`}>
      سریال‌ها
    </a>

    <a href={`${base}books`}>
      کتاب‌ها
    </a>

    <a href={`${base}music`}>
      موسیقی
    </a>

    <a href={`${base}stats`}>
      آمار
    </a>

    <a href={`${base}timeline`}>
      خط زمانی
    </a>

    <a href={`${base}replay`}>
      بازپخش سالانه
    </a>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
  }

  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;

    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  nav a {
    text-decoration: none;
    color: inherit;
  }
</style>