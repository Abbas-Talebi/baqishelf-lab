---
import Rating from "./Rating.astro";
import StatusBadge from "./StatusBadge.astro";
import Cover from "./Cover.astro";
import { getStatusLabel } from "../utils/helpers";

const { music } = Astro.props;

const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}music/${music.id}`}
  class="card"
  data-title={music.data.title}
  data-status={music.data.status}
  data-rating={music.data.personal_rating}
  data-year={music.data.year}
  data-genres={music.data.genres?.join(",")}
  data-tags={music.data.tags?.join(",")}
  data-date={music.data.date_listened?.getTime() ?? 0}
>
  <Cover
    src={`${base}covers/${music.data.cover}`}
    alt={music.data.title}
    type={music.data.cover_type}
  />

  <div class="info">
    {
      music.data.tags?.includes("favorite") && (
        <span class="favorite-badge">
          ★ Favorite
        </span>
      )
    }

    <h2>{music.data.title}</h2>

    {
      music.data.artist && (
        <p class="artist">
          🎤 {music.data.artist}
        </p>
      )
    }

    <Rating value={music.data.personal_rating} />

    <p>{music.data.year}</p>

    <p>{music.data.genres?.join("، ")}</p>

    <span class="status-badge">
      {getStatusLabel(music.data.status)}
    </span>
  </div>
</a>

<style>
.card {
  display: flex;
  gap: 1rem;
  padding: 1rem;
  border: 1px solid #2a2a2a;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
  margin-bottom: 1rem;
  transition: 0.2s;
}

.card:hover {
  transform: translateY(-2px);
}

.info {
  flex: 1;
}

.info h2 {
  margin-top: 0;
  margin-bottom: 0.5rem;
}

.artist {
  opacity: 0.8;
  margin-bottom: 0.5rem;
}

.favorite-badge {
  display: inline-block;
  margin-bottom: 0.5rem;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  border: 1px solid #444;
  font-size: 0.8rem;
}

.status-badge {
  display: inline-block;
  margin-top: 0.5rem;
  padding: 0.25rem 0.75rem;
  border: 1px solid #444;
  border-radius: 999px;
  font-size: 0.85rem;
}
</style>