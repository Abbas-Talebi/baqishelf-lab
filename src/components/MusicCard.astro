---
import Rating from "./Rating.astro";
import StatusBadge from "./StatusBadge.astro";
import Cover from "./Cover.astro";
import { getStatusLabel } from "../utils/helpers";

const { music } = Astro.props;

const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}music/${music.id}`}
  class="card"
  data-title={music.data.title}
  data-status={music.data.status}
  data-rating={music.data.personal_rating}
  data-year={music.data.year}
  data-genres={music.data.genres?.join(",")}
  data-tags={music.data.tags?.join(",")}
  data-date={music.data.date_listened?.getTime() ?? 0}
>
  <Cover
    src={`${base}covers/${music.data.cover}`}
    alt={music.data.title}
    type={music.data.cover_type}
  />

  <div class="info">
    {
      music.data.tags?.includes("favorite") && (
        <span class="favorite-badge">
          ★ Favorite
        </span>
      )
    }

    <h2>{music.data.title}</h2>

    {
      music.data.artist && (
        <p class="artist">
          🎤 {music.data.artist}
        </p>
      )
    }

    <Rating value={music.data.personal_rating} />

    <p>{music.data.year}</p>

    <p>{music.data.genres?.join("، ")}</p>

    <span class="status-badge">
      {getStatusLabel(music.data.status)}
    </span>
  </div>
</a>

<style>
.card {
  display: flex;
  gap: 1.5rem;
  padding: 1rem;
  border: 1px solid #2a2a2a;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
  margin-bottom: 1rem;
  transition: 0.2s;
  overflow: hidden; /* جلوگیری از بیرون زدن محتوا */
}

.card:hover {
  transform: translateY(-2px);
}

.info {
  flex: 1;
  min-width: 0; /* این خط جادویی از بیرون زدن متن‌های طولانی جلوگیری می‌کند */
}

.info h2 {
  margin-top: 0;
  font-size: 1.5rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis; /* اگر اسم فیلم طولانی بود، سه نقطه می‌گذارد */
}

/* بقیه استایل‌های قبلی تگ‌ها و بج‌ها را نگه دار... */

/* تنظیمات مخصوص موبایل */
@media (max-width: 600px) {
  .card {
    gap: 1rem;
    padding: 0.8rem;
  }
  .info h2 {
    font-size: 1.2rem;
    white-space: normal; /* در موبایل اجازه می‌دهیم اسم فیلم دو خط شود */
  }
  .info p {
    font-size: 0.9rem;
    margin: 0.3rem 0;
  }
}
</style>