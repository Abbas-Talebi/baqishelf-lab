---
import Rating from "./Rating.astro";
import Cover from "./Cover.astro";
import { getStatusLabel } from "../utils/helpers";

const { game } = Astro.props;

const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}games/${game.id}`}
  class="card"
  data-title={game.data.title}
  data-status={game.data.status}
  data-rating={game.data.personal_rating}
  data-year={game.data.year}
  data-platforms={game.data.platforms?.join(",")}
  data-genres={game.data.genres?.join(",")}
  data-tags={game.data.tags?.join(",")}
  data-date={game.data.date_finished?.getTime() ?? 0}
>

  {
    game.data.cover && (
      <Cover
        src={`${base}covers/${game.data.cover}`}
        alt={game.data.title}
        type={game.data.cover_type}
      />
    )
  }

  <div class="info">

    {
      game.data.tags?.includes("favorite") && (
        <span class="favorite-badge">
          ★ Favorite
        </span>
      )
    }

    <h2>{game.data.title}</h2>

    <Rating value={game.data.personal_rating} />

    <p>{game.data.year}</p>

    <p>{game.data.platforms?.join("، ")}</p>

    <span class="status-badge">
      {getStatusLabel(game.data.status)}
    </span>

  </div>

</a>

<style>
.card {
  display: flex;
  gap: 1.5rem;
  padding: 1rem;
  border: 1px solid #2a2a2a;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
  margin-bottom: 1rem;
  transition: 0.2s;
  overflow: hidden; /* جلوگیری از بیرون زدن محتوا */
}

.card:hover {
  transform: translateY(-2px);
}

.info {
  flex: 1;
  min-width: 0; /* این خط جادویی از بیرون زدن متن‌های طولانی جلوگیری می‌کند */
}

.info h2 {
  margin-top: 0;
  font-size: 1.5rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis; /* اگر اسم فیلم طولانی بود، سه نقطه می‌گذارد */
}

/* بقیه استایل‌های قبلی تگ‌ها و بج‌ها را نگه دار... */

/* تنظیمات مخصوص موبایل */
@media (max-width: 600px) {
  .card {
    gap: 1rem;
    padding: 0.8rem;
  }
  .info h2 {
    font-size: 1.2rem;
    white-space: normal; /* در موبایل اجازه می‌دهیم اسم فیلم دو خط شود */
  }
  .info p {
    font-size: 0.9rem;
    margin: 0.3rem 0;
  }
}
</style>