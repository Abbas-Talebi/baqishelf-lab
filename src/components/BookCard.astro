---
import Rating from "./Rating.astro";
import StatusBadge from "./StatusBadge.astro";
import Cover from "./Cover.astro";

const { book } = Astro.props;

const statusMap = {
  completed: "✓ خوانده شده",
  reading: "📖 در حال خواندن",
  planned: "📋 برنامه مطالعه",
  dropped: "✕ رها شده",
};
---

<a
  href={`/books/${book.id}`}
  class="card"
  data-title={book.data.title}
  data-status={book.data.status}
  data-rating={book.data.personal_rating}
  data-year={book.data.year}
  data-genres={book.data.genres?.join(" ")}
  data-tags={book.data.tags?.join(" ")}
>

  <Cover
  src={`/covers/${book.data.cover}`}
  alt={book.data.title}
  type={book.data.cover_type}
/>

  <div class="info">

    {
      book.data.tags?.includes("favorite") && (
        <span class="favorite-badge">
          ★ Favorite
        </span>
      )
    }

    <h2>{book.data.title}</h2>

    <Rating
      value={book.data.personal_rating}
    />

    {
      book.data.author && (
        <p>
          ✍️ {book.data.author}
        </p>
      )
    }

    <p>
      {book.data.year}
    </p>

    <p>
      {book.data.genres?.join(", ")}
    </p>

    {
      book.data.pages && (
        <p>
          📄 {book.data.pages} صفحه
        </p>
      )
    }

    <span class="status-badge">
      {
        statusMap[
          book.data.status
        ] ?? book.data.status
      }
    </span>

  </div>

</a>

<style>
.card {
  display: flex;
  gap: 1rem;
  padding: 1rem;
  border: 1px solid #2a2a2a;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
  margin-bottom: 1rem;
  transition: 0.2s;
}

.card:hover {
  transform: translateY(-2px);
}



.info h2 {
  margin-top: 0;
}

.favorite-badge {
  display: inline-block;
  margin-bottom: 0.5rem;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  border: 1px solid #444;
  font-size: 0.8rem;
}

.status-badge {
  display: inline-block;
  margin-top: 0.5rem;
  padding: 0.25rem 0.75rem;
  border: 1px solid #444;
  border-radius: 999px;
  font-size: 0.85rem;
}
</style>