---
import Rating from "./Rating.astro";
import StatusBadge from "./StatusBadge.astro";
import Cover from "./Cover.astro";

const { book } = Astro.props;

const base = import.meta.env.BASE_URL;

const statusMap = {
  completed: "✓ خوانده شده",
  reading: "📖 در حال خواندن",
  planned: "📋 برنامه مطالعه",
  dropped: "✕ رها شده",
};
---

<a
  href={`${base}books/${book.id}`}
  class="card"
  data-title={book.data.title}
  data-status={book.data.status}
  data-rating={book.data.personal_rating}
  data-year={book.data.year}
  data-genres={book.data.genres?.join(" ")}
  data-tags={book.data.tags?.join(" ")}
>

  <Cover
    src={`${base}covers/${book.data.cover}`}
    alt={book.data.title}
    type={book.data.cover_type}
  />

  <div class="info">

    {
      book.data.tags?.includes("favorite") && (
        <span class="favorite-badge">
          ★ Favorite
        </span>
      )
    }

    <h2>{book.data.title}</h2>

    <Rating
      value={book.data.personal_rating}
    />

    {
      book.data.author && (
        <p>
          ✍️ {book.data.author}
        </p>
      )
    }

    <p>
      {book.data.year}
    </p>

    <p>
      {book.data.genres?.join(", ")}
    </p>

    {
      book.data.pages && (
        <p>
          📄 {book.data.pages} صفحه
        </p>
      )
    }

    <span class="status-badge">
      {
        statusMap[
          book.data.status
        ] ?? book.data.status
      }
    </span>

  </div>

</a>

<style>
.card {
  display: flex;
  gap: 1.5rem;
  padding: 1rem;
  border: 1px solid #2a2a2a;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
  margin-bottom: 1rem;
  transition: 0.2s;
  overflow: hidden; /* جلوگیری از بیرون زدن محتوا */
}

.card:hover {
  transform: translateY(-2px);
}

.info {
  flex: 1;
  min-width: 0; /* این خط جادویی از بیرون زدن متن‌های طولانی جلوگیری می‌کند */
}

.info h2 {
  margin-top: 0;
  font-size: 1.5rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis; /* اگر اسم فیلم طولانی بود، سه نقطه می‌گذارد */
}

/* بقیه استایل‌های قبلی تگ‌ها و بج‌ها را نگه دار... */

/* تنظیمات مخصوص موبایل */
@media (max-width: 600px) {
  .card {
    gap: 1rem;
    padding: 0.8rem;
  }
  .info h2 {
    font-size: 1.2rem;
    white-space: normal; /* در موبایل اجازه می‌دهیم اسم فیلم دو خط شود */
  }
  .info p {
    font-size: 0.9rem;
    margin: 0.3rem 0;
  }
}
</style>