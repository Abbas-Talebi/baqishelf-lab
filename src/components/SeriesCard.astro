---
import Rating from "./Rating.astro";
import StatusBadge from "./StatusBadge.astro";
import Cover from "./Cover.astro";
import { getStatusLabel } from "../utils/helpers";

const { series } = Astro.props;

const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}series/${series.id}`}
  class="card"
  data-title={series.data.title}
  data-status={series.data.status}
  data-rating={series.data.personal_rating}
  data-year={series.data.year}
  data-genres={series.data.genres?.join(",")}
  data-tags={series.data.tags?.join(",")}
  data-date={series.data.date_watched?.getTime() ?? 0}
>
  <Cover
    src={`${base}covers/${series.data.cover}`}
    alt={series.data.title}
    type={series.data.cover_type}
  />

  <div class="info">

    {
      series.data.tags?.includes("favorite") && (
        <span class="favorite-badge">
          ★ Favorite
        </span>
      )
    }

    <h2>{series.data.title}</h2>

    <Rating
      value={series.data.personal_rating}
    />

    <p>{series.data.year}</p>

    <p>
      {series.data.genres?.join("، ")}
    </p>

    <span class="status-badge">
      {getStatusLabel(series.data.status)}
    </span>

    {
      series.data.date_watched && (
        <p class="date-watched">
          📅 {series.data.date_watched.toLocaleDateString("fa-IR")}
        </p>
      )
    }

  </div>
</a>

<style>
.card {
  display: flex;
  gap: 1.5rem;
  padding: 1rem;
  border: 1px solid #2a2a2a;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
  margin-bottom: 1rem;
  transition: 0.2s;
  overflow: hidden; /* جلوگیری از بیرون زدن محتوا */
}

.card:hover {
  transform: translateY(-2px);
}

.info {
  flex: 1;
  min-width: 0; /* این خط جادویی از بیرون زدن متن‌های طولانی جلوگیری می‌کند */
}

.info h2 {
  margin-top: 0;
  font-size: 1.5rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis; /* اگر اسم فیلم طولانی بود، سه نقطه می‌گذارد */
}

/* بقیه استایل‌های قبلی تگ‌ها و بج‌ها را نگه دار... */

/* تنظیمات مخصوص موبایل */
@media (max-width: 600px) {
  .card {
    gap: 1rem;
    padding: 0.8rem;
  }
  .info h2 {
    font-size: 1.2rem;
    white-space: normal; /* در موبایل اجازه می‌دهیم اسم فیلم دو خط شود */
  }
  .info p {
    font-size: 0.9rem;
    margin: 0.3rem 0;
  }
}
</style>