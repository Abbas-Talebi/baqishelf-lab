---
import Rating from "./Rating.astro";
import StatusBadge from "./StatusBadge.astro";
import Cover from "./Cover.astro";
import { getStatusLabel } from "../utils/helpers";

const { series } = Astro.props;

const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}series/${series.id}`}
  class="card"
  data-title={series.data.title}
  data-status={series.data.status}
  data-rating={series.data.personal_rating}
  data-year={series.data.year}
  data-genres={series.data.genres?.join(",")}
  data-tags={series.data.tags?.join(",")}
  data-date={series.data.date_watched?.getTime() ?? 0}
>
  <Cover
    src={`${base}covers/${series.data.cover}`}
    alt={series.data.title}
    type={series.data.cover_type}
  />

  <div class="info">

    {
      series.data.tags?.includes("favorite") && (
        <span class="favorite-badge">
          ★ Favorite
        </span>
      )
    }

    <h2>{series.data.title}</h2>

    <Rating
      value={series.data.personal_rating}
    />

    <p>{series.data.year}</p>

    <p>
      {series.data.genres?.join("، ")}
    </p>

    <span class="status-badge">
      {getStatusLabel(series.data.status)}
    </span>

    {
      series.data.date_watched && (
        <p class="date-watched">
          📅 {series.data.date_watched.toLocaleDateString("fa-IR")}
        </p>
      )
    }

  </div>
</a>

<style>
.card {
  display: flex;
  gap: 1rem;
  border: 1px solid #333;
  border-radius: 12px;
  padding: 1rem;
  text-decoration: none;
  color: inherit;
  margin-bottom: 1rem;
  transition: 0.2s;
}

.card:hover {
  transform: translateY(-2px);
}

.info h2 {
  margin-top: 0;
}

.date-watched {
  font-size: 0.8rem;
  opacity: 0.7;
  margin-top: 0.5rem;
}

.favorite-badge {
  display: inline-block;
  margin-bottom: 0.5rem;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  border: 1px solid #444;
  font-size: 0.8rem;
}

.status-badge {
  display: inline-block;
  margin-top: 0.5rem;
  padding: 0.25rem 0.75rem;
  border: 1px solid #444;
  border-radius: 999px;
  font-size: 0.85rem;
}
</style>