---
import Rating from "./Rating.astro";
import StatusBadge from "./StatusBadge.astro";
import Cover from "./Cover.astro";

const { movie } = Astro.props;

const statusMap = {
  watched: "✓ Watched",
  watching: "🎬 Watching",
  planned: "📋 Planned",
  dropped: "✕ Dropped",
};
---

<a
  href={`/movies/${movie.id}`}
  class="card"
  data-title={movie.data.title}
  data-status={movie.data.status}
  data-rating={movie.data.personal_rating}
  data-year={movie.data.year}
  data-genres={movie.data.genres?.join(" ")}
  data-tags={movie.data.tags?.join(" ")}
>

  <Cover
  src={`/covers/${movie.data.cover}`}
  alt={movie.data.title}
  type={movie.data.cover_type}
/>

  <div class="info">

    {
      movie.data.tags?.includes("favorite") && (
        <span class="favorite-badge">
          ★ Favorite
        </span>
      )
    }

    <h2>{movie.data.title}</h2>

    <Rating
      value={movie.data.personal_rating}
    />

    <p>
      {movie.data.year}
    </p>

    <p>
      {movie.data.genres?.join(", ")}
    </p>

    <span class="status-badge">
      {
        statusMap[
          movie.data.status
        ] ?? movie.data.status
      }
    </span>

  </div>

</a>

<style>
.card {
  display: flex;
  gap: 1rem;

  padding: 1rem;

  border: 1px solid #2a2a2a;

  border-radius: 12px;

  text-decoration: none;

  color: inherit;

  margin-bottom: 1rem;

  transition: 0.2s;
}

.card:hover {
  transform: translateY(-2px);
}


.info h2 {
  margin-top: 0;
}

.favorite-badge {
  display: inline-block;

  margin-bottom: 0.5rem;

  padding: 0.2rem 0.6rem;

  border-radius: 999px;

  border: 1px solid #444;

  font-size: 0.8rem;
}

.status-badge {
  display: inline-block;

  margin-top: 0.5rem;

  padding: 0.25rem 0.75rem;

  border: 1px solid #444;

  border-radius: 999px;

  font-size: 0.85rem;
}
</style>