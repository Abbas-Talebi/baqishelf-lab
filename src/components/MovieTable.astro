---
import Rating from "./Rating.astro";

const { movies } = Astro.props;

const base = import.meta.env.BASE_URL;

const statusMap = {
  watched: "✓ تماشا شده",
  watching: "🎬 در حال تماشا",
  planned: "📋 برنامه تماشا",
  dropped: "✕ رها شده",
};
---

<table class="movie-table">
  <thead>
    <tr>
      <th>کاور</th>
      <th data-sort="string">عنوان ↕</th>
      <th data-sort="number">امتیاز ↕</th>
      <th data-sort="number">سال ↕</th>
      <th data-sort="string">ژانر ↕</th>
      <th>وضعیت</th>
      <th data-sort="date">تاریخ تماشا ↕</th>
    </tr>
  </thead>

  <tbody>
    {
      movies.map((movie) => (
        <tr>
          <td>
            {
              movie.data.cover && (
                <img
                  src={`${base}covers/${movie.data.cover}`}
                  alt={movie.data.title}
                  class="cover"
                />
              )
            }
          </td>

          <td data-value={movie.data.title}>
            <a href={`${base}movies/${movie.id}`}>
              {movie.data.title}
            </a>
          </td>

          <td data-value={movie.data.personal_rating}>
            <Rating value={movie.data.personal_rating} />
          </td>

          <td data-value={movie.data.year}>
            {movie.data.year}
          </td>

          <td data-value={movie.data.genres?.join(", ") ?? ""}>
            {movie.data.genres?.join("، ")}
          </td>

          <td data-value={movie.data.status}>
            {statusMap[movie.data.status]}
          </td>

          <td data-value={movie.data.date_watched?.getTime() ?? 0}>
            {movie.data.date_watched?.toLocaleDateString("fa-IR")}
          </td>
        </tr>
      ))
    }
  </tbody>
</table>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const table = document.querySelector(".movie-table");
    if (!table) return;

    const headers = table.querySelectorAll("th[data-sort]");

    headers.forEach((header) => {
      let ascending = true;
      header.style.cursor = "pointer";

      header.addEventListener("click", () => {
        const tbody = table.querySelector("tbody");
        const rows = Array.from(tbody.querySelectorAll("tr"));

        const columnIndex = header.cellIndex;
        const sortType = header.dataset.sort;

        rows.sort((a, b) => {
          const aCell = a.children[columnIndex];
          const bCell = b.children[columnIndex];

          let aVal = aCell?.dataset?.value ?? "";
          let bVal = bCell?.dataset?.value ?? "";

          if (sortType === "number" || sortType === "date") {
            aVal = Number(aVal);
            bVal = Number(bVal);

            return ascending
              ? aVal - bVal
              : bVal - aVal;
          }

          return ascending
            ? String(aVal).localeCompare(String(bVal))
            : String(bVal).localeCompare(String(aVal));
        });

        ascending = !ascending;
        tbody.replaceChildren(...rows);
      });
    });
  });
</script>

<style>
  .movie-table {
    width: 100%;
    border-collapse: collapse;
  }

  .movie-table th,
  .movie-table td {
    padding: 0.75rem;
    text-align: center;
    vertical-align: middle;
    border-bottom: 1px solid #2a2a2a;
  }

  .cover {
    width: 60px;
    height: 90px;
    object-fit: cover;
    border-radius: 6px;
  }

  .movie-table td a {
    text-decoration: none;
  }
</style>