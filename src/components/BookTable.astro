---
import Rating from "./Rating.astro";

const { books } = Astro.props;

const base = import.meta.env.BASE_URL;

const statusMap = {
  completed: "✓ خوانده شده",
  reading: "📖 در حال خواندن",
  planned: "📋 برنامه مطالعه",
  dropped: "✕ رها شده",
};
---

<table class="book-table">
  <thead>
    <tr>
      <th>کاور</th>
      <th data-sort="string">عنوان ↕</th>
      <th data-sort="string">نویسنده ↕</th>
      <th data-sort="number">امتیاز ↕</th>
      <th data-sort="number">سال ↕</th>
      <th data-sort="number">صفحات ↕</th>
      <th data-sort="string">ژانر ↕</th>
      <th>وضعیت</th>
      <th data-sort="date">تاریخ پایان ↕</th>
    </tr>
  </thead>

  <tbody>
    {
      books.map((book) => (
        <tr>
          <td>
            {
              book.data.cover && (
                <img
                  src={`${base}covers/${book.data.cover}`}
                  alt={book.data.title}
                  class="cover"
                />
              )
            }
          </td>

          <td data-value={book.data.title}>
            <a href={`${base}books/${book.id}`}>
              {book.data.title}
            </a>
          </td>

          <td data-value={book.data.author ?? ""}>
            {book.data.author}
          </td>

          <td data-value={book.data.personal_rating}>
            <Rating value={book.data.personal_rating} />
          </td>

          <td data-value={book.data.year}>
            {book.data.year}
          </td>

          <td data-value={book.data.pages ?? 0}>
            {book.data.pages}
          </td>

          <td data-value={book.data.genres?.join(", ") ?? ""}>
            {book.data.genres?.join("، ")}
          </td>

          <td data-value={book.data.status}>
            {statusMap[book.data.status]}
          </td>

          <td data-value={book.data.date_finished?.getTime() ?? 0}>
            {book.data.date_finished?.toLocaleDateString("fa-IR")}
          </td>
        </tr>
      ))
    }
  </tbody>
</table>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const table = document.querySelector(".book-table");
    if (!table) return;

    const headers = table.querySelectorAll("th[data-sort]");

    headers.forEach((header) => {
      let ascending = true;

      header.style.cursor = "pointer";

      header.addEventListener("click", () => {
        const tbody = table.querySelector("tbody");
        if (!tbody) return;

        const rows = Array.from(
          tbody.querySelectorAll("tr")
        );

        const columnIndex = header.cellIndex;
        const sortType = header.dataset.sort;

        rows.sort((a, b) => {
          const aCell = a.children[columnIndex];
          const bCell = b.children[columnIndex];

          let aVal =
            aCell?.dataset?.value ?? "";

          let bVal =
            bCell?.dataset?.value ?? "";

          if (
            sortType === "number" ||
            sortType === "date"
          ) {
            return ascending
              ? Number(aVal) - Number(bVal)
              : Number(bVal) - Number(aVal);
          }

          return ascending
            ? String(aVal).localeCompare(
                String(bVal)
              )
            : String(bVal).localeCompare(
                String(aVal)
              );
        });

        ascending = !ascending;

        tbody.replaceChildren(...rows);
      });
    });
  });
</script>

<style>
.book-table {
  width: 100%;
  border-collapse: collapse;
}

.book-table th,
.book-table td {
  padding: 0.75rem;
  text-align: center;
  vertical-align: middle;
  border-bottom: 1px solid #2a2a2a;
}

.cover {
  width: 60px;
  height: 90px;
  object-fit: cover;
  border-radius: 6px;
}

.book-table td a {
  text-decoration: none;
}
</style>