---
const {
  src,
  alt,
  type = "poster",
} = Astro.props;

// ایجاد یک Cache Buster بر اساس زمان بیلد سایت
// این کار باعث می‌شود هر بار که سایت را آپدیت (Push) می‌کنید، 
// مرورگر کاربران مجبور شود عکس‌ها را دوباره چک کند و کَش قدیمی را دور بریزد.
const cacheBuster = Date.now().toString(36);
const imageUrl = `${src}?v=${cacheBuster}`;
---

<img
  src={imageUrl}
  alt={alt}
  loading="lazy"
  decoding="async"
  class={`cover ${type}`}
/>

<style>
.cover {
  display: block;
  object-fit: cover;
  border-radius: 12px;
  flex-shrink: 0;
  transition: transform .25s ease, filter .25s ease;
  background-color: #222;
  width: 100%; /* تغییر جدید */
}

.cover:hover {
  transform: scale(1.02);
}

.cover.poster {
  max-width: 180px; /* در کامپیوتر حداکثر 180 پیکسل */
  aspect-ratio: 2 / 3;
}

.cover.square {
  max-width: 180px;
  aspect-ratio: 1 / 1;
}

/* تنظیمات مخصوص موبایل */
@media (max-width: 600px) {
  .cover.poster, .cover.square {
    max-width: 100px; /* در موبایل عکس‌ها کوچک می‌شوند تا جا برای متن باز شود */
    border-radius: 8px;
  }
}
</style>