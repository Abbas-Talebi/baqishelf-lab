---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import SeriesTable from "../../components/SeriesTable.astro";
import ViewSwitcher from "../../components/ViewSwitcher.astro";

const base = import.meta.env.BASE_URL;
const series = await getCollection("series");

const sortedSeries = [...series].sort(
  (a, b) => b.data.personal_rating - a.data.personal_rating
);
---

<BaseLayout title="جدول سریال‌ها">
  <h1>📺 جدول سریال‌ها</h1>

  <ViewSwitcher basePath={`${base}series`} />

  <p style="color: #888; margin-bottom: 1.5rem;">
    تعداد سریال‌ها: <strong style="color: #fff;">{series.length}</strong> 
    <span style="font-size: 0.85rem; opacity: 0.7;">(برای مرتب‌سازی روی عناوین ستون‌ها کلیک کنید)</span>
  </p>

  <SeriesTable series={sortedSeries} />
</BaseLayout>

<style>
  h1 { font-size: 2.5rem; margin-bottom: 2rem; color: #fff; }
</style>