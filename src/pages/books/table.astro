---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import BookTable from "../../components/BookTable.astro";
import ViewSwitcher from "../../components/ViewSwitcher.astro";

const base = import.meta.env.BASE_URL;
const books = await getCollection("books");

const sortedBooks = [...books].sort(
  (a, b) => b.data.personal_rating - a.data.personal_rating
);
---

<BaseLayout title="جدول کتاب‌ها">
  <h1>📚 جدول کتاب‌ها</h1>

  <ViewSwitcher basePath={`${base}books`} />

  <p style="color: #888; margin-bottom: 1.5rem;">
    تعداد کتاب‌ها: <strong style="color: #fff;">{books.length}</strong> 
    <span style="font-size: 0.85rem; opacity: 0.7;">(برای مرتب‌سازی روی عناوین ستون‌ها کلیک کنید)</span>
  </p>

  <BookTable books={sortedBooks} />
</BaseLayout>

<style>
  h1 { font-size: 2.5rem; margin-bottom: 2rem; color: #fff; }
</style>