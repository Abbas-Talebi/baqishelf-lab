---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import MovieTable from "../../components/MovieTable.astro";
import ViewSwitcher from "../../components/ViewSwitcher.astro";

const base = import.meta.env.BASE_URL;
const movies = await getCollection("movies");

const sortedMovies = [...movies].sort(
  (a, b) => b.data.personal_rating - a.data.personal_rating
);
---

<BaseLayout title="جدول فیلم‌ها">
  <h1>🎬 جدول فیلم‌ها</h1>

  <ViewSwitcher basePath={`${base}movies`} />

  <p style="color: #888; margin-bottom: 1.5rem;">
    تعداد فیلم‌ها: <strong style="color: #fff;">{movies.length}</strong> 
    <span style="font-size: 0.85rem; opacity: 0.7;">(برای مرتب‌سازی روی عناوین ستون‌ها کلیک کنید)</span>
  </p>

  <MovieTable movies={sortedMovies} />
</BaseLayout>

<style>
  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: #fff;
  }
</style>