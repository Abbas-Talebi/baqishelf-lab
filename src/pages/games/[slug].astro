---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Rating from "../../components/Rating.astro";
import { getCollection, render } from "astro:content";

const base = import.meta.env.BASE_URL;

const statusMap = {
  completed: "✓ تکمیل شده",
  playing: "🎮 در حال تجربه",
  backlog: "📚 در صف",
  paused: "⏸ متوقف شده",
  dropped: "✕ رها شده",
};

export async function getStaticPaths() {
  const games = await getCollection("games");
  return games.map((game) => ({
    params: { slug: game.id },
    props: { game },
  }));
}

const { game } = Astro.props;
const { Content } = await render(game);

const genres = game.data.genres ?? [];
const tags = game.data.tags ?? [];
const platforms = game.data.platforms ?? [];
const coverUrl = game.data.cover ? `${base}covers/${game.data.cover}` : '';
---

<BaseLayout title={game.data.title}>

  <!-- هدر حرفه‌ای با پس‌زمینه تار -->
  <div class="hero-banner" style={coverUrl ? `background-image: url('${coverUrl}')` : ''}>
    <div class="hero-overlay">
      <div class="hero-content">
        
        {game.data.cover && (
          <img src={coverUrl} alt={game.data.title} class="hero-cover" />
        )}

        <div class="hero-info">
          <h1>{game.data.title}</h1>

          <div class="meta-row">
            <span class="year">{game.data.year}</span>
            <span class="status-badge">{statusMap[game.data.status] ?? game.data.status}</span>
          </div>

          <div class="rating-box">
            <strong>امتیاز شخصی:</strong>
            <Rating value={game.data.personal_rating} />
          </div>

          <div class="details-grid">
            {game.data.developer && <p><strong>توسعه‌دهنده:</strong> {game.data.developer}</p>}
            {game.data.publisher && <p><strong>ناشر:</strong> {game.data.publisher}</p>}
            {game.data.date_started && <p><strong>تاریخ شروع:</strong> {game.data.date_started.toLocaleDateString("fa-IR")}</p>}
            {game.data.date_finished && <p><strong>تاریخ اتمام:</strong> {game.data.date_finished.toLocaleDateString("fa-IR")}</p>}
            
            {game.data.achievements_unlocked !== undefined && game.data.achievements_total !== undefined && (
              <p><strong>اچیومنت‌ها:</strong> {game.data.achievements_unlocked} از {game.data.achievements_total}</p>
            )}
          </div>

          {game.data.completion_percentage !== undefined && (
            <div class="progress-section">
              <strong>درصد تکمیل ({game.data.completion_percentage}%)</strong>
              <div class="progress-bar">
                <div class="progress-fill" style={`width: ${game.data.completion_percentage}%`}></div>
              </div>
            </div>
          )}

          {platforms.length > 0 && (
            <div class="badges-section">
              <strong>پلتفرم‌ها:</strong>
              <div class="badges">
                {platforms.map((p) => <span class="badge platform-badge">{p}</span>)}
              </div>
            </div>
          )}

          {genres.length > 0 && (
            <div class="badges-section">
              <strong>ژانرها:</strong>
              <div class="badges">
                {genres.map((genre) => <span class="badge genre-badge">{genre}</span>)}
              </div>
            </div>
          )}

          {tags.length > 0 && (
            <div class="badges-section">
              <strong>تگ‌ها:</strong>
              <div class="badges">
                {tags.map((tag) => <span class="badge tag-badge">#{tag}</span>)}
              </div>
            </div>
          )}

        </div>
      </div>
    </div>
  </div>

  <!-- نمرات جزئی بازی -->
  {(game.data.story_rating || game.data.gameplay_rating || game.data.music_rating || game.data.graphics_rating || game.data.technical_rating) && (
    <div class="sub-ratings-box">
      <h3>جزئیات امتیازدهی</h3>
      <div class="sub-ratings-grid">
        {game.data.story_rating && <div><span>داستان:</span> <Rating value={game.data.story_rating} /></div>}
        {game.data.gameplay_rating && <div><span>گیم‌پلی:</span> <Rating value={game.data.gameplay_rating} /></div>}
        {game.data.music_rating && <div><span>موسیقی:</span> <Rating value={game.data.music_rating} /></div>}
        {game.data.graphics_rating && <div><span>گرافیک:</span> <Rating value={game.data.graphics_rating} /></div>}
        {game.data.technical_rating && <div><span>فنی:</span> <Rating value={game.data.technical_rating} /></div>}
      </div>
    </div>
  )}

  {game.data.summary && (
    <div class="summary-box">
      <h3>نظر کوتاه:</h3>
      <p>{game.data.summary}</p>
    </div>
  )}

  <div class="markdown-content">
    <Content />
  </div>

</BaseLayout>

<style>
  .hero-banner { width: 100%; border-radius: 20px; overflow: hidden; margin-bottom: 2rem; background-size: cover; background-position: center; background-color: #1a1a1a; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
  .hero-overlay { background: linear-gradient(90deg, rgba(17,17,17,1) 0%, rgba(17,17,17,0.85) 50%, rgba(17,17,17,0.6) 100%); backdrop-filter: blur(15px); padding: 3rem; }
  .hero-content { display: flex; gap: 3rem; align-items: flex-start; }
  .hero-cover { width: 280px; border-radius: 12px; box-shadow: 0 8px 25px rgba(0,0,0,0.6); flex-shrink: 0; }
  .hero-info { flex: 1; display: flex; flex-direction: column; gap: 1.2rem; min-width: 0; }
  .hero-info h1 { margin: 0; font-size: 2.5rem; line-height: 1.3; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }
  
  .meta-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .year { font-size: 1.2rem; opacity: 0.8; }
  .status-badge { background: rgba(139, 92, 246, 0.2); color: #c4b5fd; border: 1px solid #8b5cf6; padding: 0.2rem 0.8rem; border-radius: 999px; font-size: 0.9rem; }
  
  .rating-box { background: rgba(0,0,0,0.3); padding: 0.8rem 1.2rem; border-radius: 10px; display: inline-flex; align-items: center; gap: 1rem; width: fit-content; border: 1px solid rgba(255,255,255,0.1); }
  
  .details-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; background: rgba(0,0,0,0.2); padding: 1.5rem; border-radius: 12px; }
  .details-grid p { margin: 0; font-size: 0.95rem; line-height: 1.5; }
  .details-grid strong { color: #a0a0a0; display: block; margin-bottom: 0.3rem; }

  .progress-section { background: rgba(0,0,0,0.2); padding: 1rem 1.5rem; border-radius: 12px; }
  .progress-section strong { color: #a0a0a0; font-size: 0.9rem; display: block; margin-bottom: 0.5rem; }
  .progress-bar { width: 100%; height: 10px; background: #333; border-radius: 999px; overflow: hidden; }
  .progress-fill { height: 100%; background: linear-gradient(90deg, #10b981, #34d399); border-radius: 999px; }

  .badges-section { display: flex; flex-direction: column; gap: 0.5rem; }
  .badges-section strong { color: #a0a0a0; font-size: 0.9rem; }
  .badges { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .badge { padding: 0.3rem 0.8rem; border-radius: 6px; font-size: 0.85rem; }
  .genre-badge { background: #2a2a2a; border: 1px solid #444; }
  .platform-badge { background: rgba(59, 130, 246, 0.1); color: #93c5fd; border: 1px solid rgba(59, 130, 246, 0.3); }
  .tag-badge { background: rgba(16, 185, 129, 0.1); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.3); }

  .sub-ratings-box { background: #1a1a1a; padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem; border: 1px solid #333; }
  .sub-ratings-box h3 { margin-top: 0; margin-bottom: 1rem; font-size: 1.2rem; color: #8b5cf6; }
  .sub-ratings-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1rem;
}
  .sub-ratings-grid div {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  flex: 0 0 auto;
  background: #222;
  padding: 0.8rem 1rem;
  border-radius: 8px;
  border: 1px solid #333;
}
  
  .summary-box { background: #1a1a1a; border-right: 4px solid #8b5cf6; padding: 1.5rem; border-radius: 8px; margin-bottom: 2rem; }
  .summary-box h3 { margin-top: 0; margin-bottom: 0.5rem; font-size: 1.1rem; }
  .summary-box p { margin: 0; opacity: 0.9; line-height: 1.8; }
  .markdown-content { line-height: 1.8; font-size: 1.05rem; }

  @media (max-width: 768px) {
    .hero-overlay { background: linear-gradient(0deg, rgba(17,17,17,1) 0%, rgba(17,17,17,0.95) 50%, rgba(17,17,17,0.6) 100%); padding: 2rem 1.5rem; }
    .hero-content { flex-direction: column; align-items: center; text-align: center; gap: 1.5rem; }
    .hero-cover { width: 200px; }
    .meta-row { justify-content: center; }
    .rating-box { margin: 0 auto; }
    .badges { justify-content: center; }
    .details-grid { grid-template-columns: 1fr; text-align: right; }
  }
</style>