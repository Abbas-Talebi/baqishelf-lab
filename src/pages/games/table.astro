---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import GameTable from "../../components/GameTable.astro";

const base = import.meta.env.BASE_URL;

const gamesUrl = `${base}games`;
const gamesTableUrl = `${base}games/table`;

const games =
  await getCollection("games");

const sortedGames =
  [...games].sort(
    (a, b) =>
      b.data.personal_rating -
      a.data.personal_rating
  );
---

<BaseLayout title="بازی‌ها - جدول">

<h1>بازی‌ها</h1>

<div class="view-switch">

  <a href={gamesUrl}>
    نمای کارت
  </a>

  <a href={gamesTableUrl}>
    نمای جدول
  </a>

</div>

<p>
  تعداد بازی‌ها:
  {games.length}
</p>

<GameTable
  games={sortedGames}
/>

<style>
.view-switch {
  display: flex;
  gap: 1rem;
  margin-bottom: 2rem;
}

.view-switch a {
  border: 1px solid #333;
  padding: 0.5rem 1rem;
  border-radius: 8px;
  text-decoration: none;
}
</style>

</BaseLayout>