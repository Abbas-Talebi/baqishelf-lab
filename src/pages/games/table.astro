---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import GameTable from "../../components/GameTable.astro";
import ViewSwitcher from "../../components/ViewSwitcher.astro";

const base = import.meta.env.BASE_URL;
const games = await getCollection("games");

const sortedGames = [...games].sort(
  (a, b) => b.data.personal_rating - a.data.personal_rating
);
---

<BaseLayout title="جدول بازی‌ها">
  <h1>🎮 جدول بازی‌ها</h1>

  <ViewSwitcher basePath={`${base}games`} />

  <p style="color: #888; margin-bottom: 1.5rem;">
    تعداد بازی‌ها: <strong style="color: #fff;">{games.length}</strong> 
    <span style="font-size: 0.85rem; opacity: 0.7;">(برای مرتب‌سازی روی عناوین ستون‌ها کلیک کنید)</span>
  </p>

  <GameTable games={sortedGames} />
</BaseLayout>

<style>
  h1 {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: #fff;
  }
</style>