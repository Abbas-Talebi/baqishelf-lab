  .total-number { font-size: 4.5rem; font-weight: 900; line-height: 1; background: linear-gradient(135deg, #fff, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .total-label { font-size: 1rem; color: #888; margin-top: 0.5rem; font-weight: bold; }

  /* =========================================
     Global Overview (4 Cards)
     ========================================= */
  .global-overview {
    display: grid;
