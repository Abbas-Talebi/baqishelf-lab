---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const games = await getCollection("games");
const movies = await getCollection("movies");
const series = await getCollection("series");
const books = await getCollection("books");
const music = await getCollection("music");

const allItems = [...games, ...movies, ...series, ...books, ...music];
const totalItems = allItems.length;

// ==========================================
// 1. آمار کلی (Global Stats)
// ==========================================
const allRatings = allItems.map(i => i.data.personal_rating).filter(r => typeof r === "number" && r > 0);
const averageRating = allRatings.length > 0 ? (allRatings.reduce((sum, r) => sum + r, 0) / allRatings.length).toFixed(2) : "0.00";

const favoriteCount = allItems.filter(i => i.data.tags?.includes("favorite")).length;

let statusCounts = { completed: 0, active: 0, planned: 0, dropped: 0 };
allItems.forEach(item => {
  const s = item.data.status;
  if (['completed', 'watched', 'listened'].includes(s)) statusCounts.completed++;
  else if (['playing', 'watching', 'reading', 'listening'].includes(s)) statusCounts.active++;
  else if (['planned', 'backlog'].includes(s)) statusCounts.planned++;
  else if (s === 'dropped') statusCounts.dropped++;
});

const globalCompletionRate = totalItems > 0 ? Math.round((statusCounts.completed / totalItems) * 100) : 0;

const getTopItem = (arr) => {
  const counts = {};
  arr.forEach(item => { if (item) counts[item] = (counts[item] || 0) + 1; });
  return Object.entries(counts).sort((a, b) => b[1] - a[1])[0]?.[0] || "نامشخص";
};

// ==========================================
// 2. آمار اختصاصی مدیوم‌ها
// ==========================================
const totalMovieRuntime = movies.reduce((sum, m) => sum + (m.data.runtime || 0), 0);
const movieHours = Math.floor(totalMovieRuntime / 60);
const topDirector = getTopItem(movies.map(m => m.data.director));

const totalSeasons = series.reduce((sum, s) => sum + (s.data.seasons || 0), 0);
const totalEpisodes = series.reduce((sum, s) => sum + (s.data.episodes || 0), 0);

const totalPages = books.reduce((sum, b) => sum + (b.data.pages || 0), 0);
const topAuthor = getTopItem(books.map(b => b.data.author));

const topArtist = getTopItem(music.map(m => m.data.artist));

const totalAchievementsUnlocked = games.reduce((sum, g) => sum + (g.data.achievements_unlocked || 0), 0);
const totalAchievements = games.reduce((sum, g) => sum + (g.data.achievements_total || 0), 0);
const achievementRate = totalAchievements > 0 ? Math.round((totalAchievementsUnlocked / totalAchievements) * 100) : 0;
const topPlatform = getTopItem(games.flatMap(g => g.data.platforms || []));

// ==========================================
// 3. ژانرها
// ==========================================
const genreCounts = {};
allItems.forEach(item => {
  item.data.genres?.forEach(genre => { genreCounts[genre] = (genreCounts[genre] ?? 0) + 1; });
});
const topGenres = Object.entries(genreCounts).sort((a, b) => b[1] - a[1]).slice(0, 5);
---

<BaseLayout title="آمار و ارقام">
  
  <!-- Hero Section (از طراحی شما) -->
  <section class="stats-hero">
    <div class="hero-glow glow-purple"></div>
    <div class="hero-glow glow-blue"></div>
    
    <div class="hero-content">
      <p class="hero-subtitle">داشبورد تحلیلی شخصی</p>
      <h1>📊 آمار و ارقام آرشیو</h1>
      <p class="hero-description">نگاهی دقیق به دستاوردها، زمان‌های صرف شده و علایق من.</p>
    </div>
    
    <div class="hero-total">
      <span class="total-number">{totalItems}</span>
      <span class="total-label">کل آثار ثبت‌شده</span>
    </div>
  </section>

  <!-- Global Overview (از طراحی شما) -->
  <section class="global-overview">
    <div class="glass-card stat-primary">
      <div class="stat-icon">⭐</div>
      <div class="stat-info">
        <h3>{averageRating}</h3>
        <p>میانگین نمرات کل</p>
      </div>
    </div>
    
    <div class="glass-card stat-primary">
      <div class="stat-icon">❤️</div>
      <div class="stat-info">
        <h3>{favoriteCount}</h3>
        <p>آثار مورد علاقه (Favorite)</p>
      </div>
    </div>

    <div class="glass-card stat-primary">
      <div class="stat-icon">✅</div>
      <div class="stat-info">
        <h3>{statusCounts.completed}</h3>
        <p>آثار تکمیل/تماشا شده</p>
      </div>
    </div>

    <div class="glass-card stat-primary progress-card">
      <div class="progress-header">
        <span>نرخ تکمیل آرشیو</span>
        <strong>{globalCompletionRate}%</strong>
      </div>
      <div class="progress-bar">
        <div class="progress-fill gradient-global" style={`width: ${globalCompletionRate}%`}></div>
      </div>
    </div>
  </section>

  <!-- بخش تحلیلی ترکیبی (Bento Grid) -->
  <section class="analytics-bento">
    
    <!-- توزیع مدیوم‌ها -->
    <div class="glass-card bento-item">
      <h3 class="section-title">توزیع مدیوم‌ها</h3>
      <div class="media-bars">
        <div class="media-bar-item"><div class="media-label"><span class="dot game"></span> بازی ({games.length})</div><div class="bar-bg"><div class="bar-fill game" style={`width: ${(games.length/totalItems)*100}%`}></div></div></div>
        <div class="media-bar-item"><div class="media-label"><span class="dot movie"></span> فیلم ({movies.length})</div><div class="bar-bg"><div class="bar-fill movie" style={`width: ${(movies.length/totalItems)*100}%`}></div></div></div>
        <div class="media-bar-item"><div class="media-label"><span class="dot series"></span> سریال ({series.length})</div><div class="bar-bg"><div class="bar-fill series" style={`width: ${(series.length/totalItems)*100}%`}></div></div></div>
        <div class="media-bar-item"><div class="media-label"><span class="dot book"></span> کتاب ({books.length})</div><div class="bar-bg"><div class="bar-fill book" style={`width: ${(books.length/totalItems)*100}%`}></div></div></div>
        <div class="media-bar-item"><div class="media-label"><span class="dot music"></span> موسیقی ({music.length})</div><div class="bar-bg"><div class="bar-fill music" style={`width: ${(music.length/totalItems)*100}%`}></div></div></div>
      </div>
    </div>

    <!-- رکوردهای جالب -->
    <div class="glass-card bento-item">
      <h3 class="section-title">رکوردهای جالب</h3>
      <div class="facts-grid">
        <div class="fact-item"><span class="fact-icon">📖</span><div class="fact-info"><span class="fact-val">{totalPages.toLocaleString()}</span><span class="fact-lbl">صفحه خوانده شده</span></div></div>
        <div class="fact-item"><span class="fact-icon">🍿</span><div class="fact-info"><span class="fact-val">{movieHours.toLocaleString()}</span><span class="fact-lbl">ساعت فیلم دیده شده</span></div></div>
        <div class="fact-item"><span class="fact-icon">📺</span><div class="fact-info"><span class="fact-val">{totalEpisodes.toLocaleString()}</span><span class="fact-lbl">قسمت سریال دیده شده</span></div></div>
        <div class="fact-item"><span class="fact-icon">🏆</span><div class="fact-info"><span class="fact-val">{totalAchievements.toLocaleString()}</span><span class="fact-lbl">اچیومنت باز شده</span></div></div>
      </div>
    </div>

    <!-- وضعیت آرشیو -->
<div class="glass-card bento-item status-card">
  <h3 class="section-title">📊 وضعیت آرشیو</h3>
  <div class="status-content">
    <!-- سمت چپ: نمودار دایره‌ای + توضیحات -->
    <div class="circular-wrapper">

  <div class="circular-progress">
    <svg viewBox="0 0 36 36" class="circular-chart" overflow="visible">
      <defs>
        <linearGradient id="progressGradient" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#8b5cf6" />
          <stop offset="50%" stop-color="#6366f1" />
          <stop offset="100%" stop-color="#3b82f6" />
        </linearGradient>
      </defs>

      <path
        class="circle-bg"
        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
      />

      <path
        class="circle"
        stroke="url(#progressGradient)"
        stroke-dasharray={`${globalCompletionRate}, 100`}
        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
      />

      <text x="18" y="20.35" class="percentage">
        {globalCompletionRate}%
      </text>
    </svg>
  </div>

  <div class="chart-labels">
    <h4>نرخ تکمیل آرشیو</h4>

    <p class="chart-sub-description">
  <span class="stat-number">{statusCounts.completed}</span>
  <span class="stat-text"> اثر از </span>
  <span class="stat-number">{totalItems}</span>
  <span class="stat-text"> اثر تکمیل شده</span>
</p>
  </div>

</div>

    <!-- سمت راست: لیست وضعیت‌ها -->
    <div class="status-list">
      <div class="s-item">
        <span class="s-dot active"></span>
        <span class="s-label">در حال تجربه:</span>
        <span class="s-line"></span>
        <strong>{statusCounts.active}</strong>
      </div>
      <div class="s-item">
        <span class="s-dot planned"></span>
        <span class="s-label">در صف / برنامه:</span>
        <span class="s-line"></span>
        <strong>{statusCounts.planned}</strong>
      </div>
      <div class="s-item">
        <span class="s-dot dropped"></span>
        <span class="s-label">رها شده:</span>
        <span class="s-line"></span>
        <strong>{statusCounts.dropped}</strong>
      </div>
    </div>
  </div>
</div>


    <!-- ۵ ژانر برتر -->
    <div class="glass-card bento-item">
      <h3 class="section-title">۵ ژانر برتر</h3>
      <div class="top-genres-list">
        {topGenres.map(([genre, count], index) => (
          <div class="genre-row">
            <span class="g-rank">#{index + 1}</span>
            <span class="g-name">{genre}</span>
            <span class="g-count">{count}</span>
          </div>
        ))}
      </div>
    </div>

  </section>

  <!-- Media Specific Dashboards (با گرید 12 ستونه متقارن) -->
  <section class="media-dashboards-grid">

    <!-- ردیف اول: ۳ کارت -->
    <div class="glass-card media-card m-movie">
      <div class="card-header"><span class="icon">🎬</span> <h2>سینما</h2></div>
      <div class="stat-list">
        <div class="stat-row"><span>تعداد فیلم‌ها:</span> <strong>{movies.length}</strong></div>
        <div class="stat-row"><span>مجموع زمان تماشا:</span> <strong>{movieHours} ساعت</strong></div>
        <div class="stat-row"><span>محبوب‌ترین کارگردان:</span> <strong>{topDirector}</strong></div>
      </div>
    </div>

    <div class="glass-card media-card m-series">
      <div class="card-header"><span class="icon">📺</span> <h2>تلویزیون</h2></div>
      <div class="stat-list">
        <div class="stat-row"><span>تعداد سریال‌ها:</span> <strong>{series.length}</strong></div>
        <div class="stat-row"><span>مجموع فصل‌ها:</span> <strong>{totalSeasons}</strong></div>
        <div class="stat-row"><span>مجموع قسمت‌ها:</span> <strong>{totalEpisodes}</strong></div>
      </div>
    </div>

    <div class="glass-card media-card m-game">
      <div class="card-header"><span class="icon">🎮</span> <h2>گیمینگ</h2></div>
      <div class="stat-list">
        <div class="stat-row"><span>تعداد بازی‌ها:</span> <strong>{games.length}</strong></div>
        <div class="stat-row"><span>محبوب‌ترین پلتفرم:</span> <strong>{topPlatform}</strong></div>
      </div>
      <div class="progress-section">
        <div class="progress-header"><span>پیشرفت اچیومنت‌ها</span><strong>{achievementRate}%</strong></div>
        <div class="progress-bar"><div class="progress-fill gradient-game" style={`width: ${achievementRate}%`}></div></div>
        <p class="progress-detail">{totalAchievementsUnlocked} از {totalAchievements} باز شده</p>
      </div>
    </div>

    <!-- ردیف دوم: ۲ کارت (پهن‌تر برای پر کردن فضا) -->
