    </div>

    <div class="glass-card media-card m-music">
      <div class="card-header"><span class="icon">🎵</span> <h2>موسیقی</h2></div>
      <div class="stat-list">
        <div class="stat-row"><span>تعداد آلبوم/قطعه:</span> <strong>{music.length}</strong></div>
        <div class="stat-row"><span>محبوب‌ترین هنرمند:</span> <strong>{topArtist}</strong></div>
      </div>
    </div>

  </section>

</BaseLayout>

<style>
  /* =========================================
     Hero Section
     ========================================= */
