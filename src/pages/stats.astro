    margin-bottom: 3rem;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .hero-glow { position: absolute; width: 250px; height: 250px; border-radius: 50%; filter: blur(90px); z-index: 0; opacity: 0.4; }
