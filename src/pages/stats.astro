  .progress-fill { height: 100%; border-radius: 999px; }
  .gradient-global { background: linear-gradient(90deg, #8b5cf6, #c4b5fd); }
  .gradient-game { background: linear-gradient(90deg, #3b82f6, #60a5fa); }

