  }

  .section-title { margin: 0 0 1.5rem 0; font-size: 1.2rem; color: #ccc; border-bottom: 1px solid #222; padding-bottom: 0.8rem; }

  /* Media Bars */
  .media-bars { display: flex; flex-direction: column; gap: 1rem; }
