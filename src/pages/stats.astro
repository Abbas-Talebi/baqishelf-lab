  .stat-info h3 { margin: 0; font-size: 2rem; color: #fff; }
  .stat-info p { margin: 0; font-size: 0.9rem; color: #888; }

  .progress-card { flex-direction: column; justify-content: center; align-items: stretch; gap: 0.8rem; }
  .progress-header { display: flex; justify-content: space-between; align-items: center; color: #ccc; font-size: 0.95rem; }
