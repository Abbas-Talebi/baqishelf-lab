---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import MusicTable from "../../components/MusicTable.astro";
import ViewSwitcher from "../../components/ViewSwitcher.astro";

const base = import.meta.env.BASE_URL;
const music = await getCollection("music");

const sortedMusic = [...music].sort(
  (a, b) => b.data.personal_rating - a.data.personal_rating
);
---

<BaseLayout title="جدول موسیقی">
  <h1>🎵 جدول موسیقی</h1>

  <ViewSwitcher basePath={`${base}music`} />

  <p style="color: #888; margin-bottom: 1.5rem;">
    تعداد آثار: <strong style="color: #fff;">{music.length}</strong> 
    <span style="font-size: 0.85rem; opacity: 0.7;">(برای مرتب‌سازی روی عناوین ستون‌ها کلیک کنید)</span>
  </p>

  <MusicTable music={sortedMusic} />
</BaseLayout>

<style>
  h1 { font-size: 2.5rem; margin-bottom: 2rem; color: #fff; }
</style>