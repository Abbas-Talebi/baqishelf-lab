<style>
  .about-container {
    position: relative;
    max-width: 900px;
    margin: 2rem auto 4rem auto;
    padding: 0 1rem;
  }

  /* افکت‌های نوری */
  .glow-circle {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    filter: blur(100px);
    z-index: 0;
    opacity: 0.4;
  }
  .glow-1 { top: -50px; right: -50px; background: #8b5cf6; }
  .glow-2 { bottom: -50px; left: -50px; background: #3b82f6; }

  /* پنل شیشه‌ای اصلی */
  .glass-panel {
    position: relative;
    z-index: 1;
    background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.01));
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    padding: 4rem 3rem;
    backdrop-filter: blur(20px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* آواتار */
  .avatar-wrapper { margin-bottom: 2rem; }
  
  .avatar-ring {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    padding: 6px;
    background: linear-gradient(135deg, #8b5cf6, #3b82f6);
    box-shadow: 0 10px 25px rgba(139, 92, 246, 0.4);
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    background: #111;
  }

  /* اطلاعات پروفایل */
  .profile-info h1 { margin: 0 0 0.5rem 0; font-size: 2.5rem; color: #fff; font-weight: 900; }
  .subtitle { margin: 0 0 2rem 0; font-size: 1.2rem; color: #c4b5fd; font-weight: normal; }

  .bio-text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #ccc;
    max-width: 650px;
    margin: 0 auto 2.5rem auto;
  }

  .bio-text p { margin-bottom: 1rem; }
  .bio-text strong { color: #fff; }

  /* آمار سریع */
  .quick-stats {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    background: rgba(0,0,0,0.3);
    padding: 1rem 2rem;
    border-radius: 16px;
    border: 1px solid #333;
  }

  .q-stat { font-size: 0.95rem; color: #fff; }
  .q-stat span { color: #888; margin-left: 0.5rem; }

  /* =========================================
     شبکه‌های اجتماعی (Grid Layout)
     ========================================= */
  .social-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    width: 100%;
    max-width: 700px;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.8rem 1rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: bold;
    font-size: 0.95rem;
    transition: transform 0.2s, filter 0.2s;
  }

  .social-btn:hover {
    transform: translateY(-3px);
    filter: brightness(1.2);
  }

  .s-icon {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  /* رنگ‌های اختصاصی برندها */
  .github { background: #24292e; color: #fff; border: 1px solid #444; }
  .linkedin { background: rgba(10, 102, 194, 0.1); color: #4da3ff; border: 1px solid rgba(10, 102, 194, 0.3); }
  .twitter { background: rgba(29, 161, 242, 0.1); color: #1da1f2; border: 1px solid rgba(29, 161, 242, 0.3); }
  .instagram { background: rgba(225, 48, 108, 0.1); color: #ff6b9e; border: 1px solid rgba(225, 48, 108, 0.3); }
  .telegram { background: rgba(0, 136, 204, 0.1); color: #0088cc; border: 1px solid rgba(0, 136, 204, 0.3); }
  .spotify { background: rgba(29, 185, 84, 0.1); color: #1db954; border: 1px solid rgba(29, 185, 84, 0.3); }
  .imdb { background: rgba(245, 197, 24, 0.1); color: #f5c518; border: 1px solid rgba(245, 197, 24, 0.3); }
  .email { background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }

  /* =========================================
     Mobile Responsive
     ========================================= */
  @media (max-width: 768px) {
    .social-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .glass-panel { padding: 3rem 1.5rem; }
    .profile-info h1 { font-size: 2rem; }
    .quick-stats { flex-direction: column; alignItems: center; gap: 0.8rem; }
    .social-grid { grid-template-columns: 1fr; }
  }
</style>