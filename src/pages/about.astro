</BaseLayout>

<style>
  .about-container {
    position: relative;
    max-width: 900px;
    margin: 2rem auto 4rem auto;
    padding: 0 1rem;
  }

  /* افکت‌های نوری */
  .glow-circle {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    filter: blur(100px);
    z-index: 0;
    opacity: 0.4;
  }
  .glow-1 { top: -50px; right: -50px; background: #8b5cf6; }
  .glow-2 { bottom: -50px; left: -50px; background: #3b82f6; }

  /* پنل شیشه‌ای اصلی */
  .glass-panel {
    position: relative;
    z-index: 1;
    background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.01));
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    padding: 4rem 3rem;
    backdrop-filter: blur(20px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* آواتار */
  .avatar-wrapper { margin-bottom: 2rem; }
  
  .avatar-ring {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    padding: 6px;
    background: linear-gradient(135deg, #8b5cf6, #3b82f6);
    box-shadow: 0 10px 25px rgba(139, 92, 246, 0.4);
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    transform: scale(1.005);
  }

  /* اطلاعات پروفایل */
  .profile-info h1 { margin: 0 0 0.5rem 0; font-size: 2.5rem; color: #fff; font-weight: 900; }
  .subtitle { margin: 0 0 2rem 0; font-size: 1.2rem; color: #c4b5fd; font-weight: normal; }

  .bio-text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #ccc;
    max-width: 650px;
    margin: 0 auto 2.5rem auto;
  }

  .bio-text p { margin-bottom: 1rem; }
  .bio-text strong { color: #fff; }

  /* آمار سریع */
  .quick-stats {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    background: rgba(0,0,0,0.3);
    padding: 1rem 2rem;
    border-radius: 16px;
    border: 1px solid #333;
  }

  .q-stat { font-size: 0.95rem; color: #fff; }
  .q-stat span { color: #888; margin-left: 0.5rem; }

  /* بخش حمایت مالی */
  .donate-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: #fbbf24;
    padding: 0.8rem 2rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: bold;
    font-size: 1rem;
    margin-bottom: 3rem;
    transition: transform 0.2s, background 0.2s;
    box-shadow: 0 4px 15px rgba(245, 158, 11, 0.1);
  }

  .donate-box:hover {
    transform: translateY(-3px);
    background: rgba(245, 158, 11, 0.2);
  }

  /* =========================================
     شبکه‌های اجتماعی (Grid Layout)
     ========================================= */
  .social-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    width: 100%;
    max-width: 700px;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
