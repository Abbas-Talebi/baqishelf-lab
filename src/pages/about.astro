---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

// =========================================================
// ⚙️ تنظیمات پروفایل (برای شخصی‌سازی قالب)
// مقادیر زیر را با اطلاعات خودتان جایگزین کنید.
// اگر لینک یا nickname را خالی بگذارید ("")، دکمه آن به طور خودکار مخفی می‌شود.
// =========================================================
const USER_PROFILE = {
  name: "باقی",
  nickname: "",
  role: "گیمر و عاشق هنر",
  avatarUrl: `${base}favicon.svg`, // مسیر آواتار شما
  
  // لینک حمایت مالی (دونیت) - مثلاً لینک زرین‌پال، حامی‌باش یا BuyMeACoffee
  donateLink: "https://zarinp.al/your_username", 
  donateText: "برای حمایت از من، یک قهوه مهمانم کنید! ☕",

  // شبکه‌های اجتماعی
  socials: {
    github: "https://github.com/abbas-talebi",
    linkedin: "https://linkedin.com/in/your_username",
    twitter: "https://twitter.com/your_username",
    instagram: "https://instagram.com/your_username",
    telegram: "https://t.me/the_baqi",
    spotify: "https://open.spotify.com/playlist/4EzIH4ab0xr4YeyaeZHIpl?si=_gqx0A-FQsqgom4o-yE4dg",
    imdb: "https://www.imdb.com/user/p.hjfnkybjzlxhgspjcvhpb2cclm",
    email: "mailto:your.email@example.com"
  }
};

// ==========================================
// محاسبات داینامیک برای آمار سریع
// ==========================================
const games = await getCollection("games");
const movies = await getCollection("movies");
const series = await getCollection("series");
const books = await getCollection("books");
const music = await getCollection("music");

const allItems = [...games, ...movies, ...series, ...books, ...music];

// 1. محاسبه علاقه اصلی
const mediaCounts = {
  "🎮 ویدیو گیم": games.length,
  "🎬 سینما": movies.length,
  "📺 تلویزیون": series.length,
  "📚 کتاب": books.length,
  "🎵 موسیقی": music.length,
};
const mainInterest = Object.keys(mediaCounts).reduce((a, b) => mediaCounts[a] > mediaCounts[b] ? a : b);

// 2. محاسبه ژانر محبوب
const genreCounts: Record<string, number> = {};
allItems.forEach(item => {
  item.data.genres?.forEach(genre => {
    genreCounts[genre] = (genreCounts[genre] || 0) + 1;
  });
});
const topGenre = Object.keys(genreCounts).length > 0 
  ? Object.keys(genreCounts).reduce((a, b) => genreCounts[a] > genreCounts[b] ? a : b) 
  : "نامشخص";

// 3. محاسبه وضعیت فعالیت
const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

const hasRecentActivity = allItems.some(item => {
  const date = item.data.date_finished || item.data.date_watched || item.data.date_listened;
  return date && new Date(date) >= thirtyDaysAgo;
});
const currentStatus = hasRecentActivity ? "🔥 بسیار فعال" : "🟢 در حال کاوش";
---

<BaseLayout title="درباره من">
  
  <div class="about-container">
    
    <!-- افکت‌های نوری پس‌زمینه -->
    <div class="glow-circle glow-1"></div>
    <div class="glow-circle glow-2"></div>

    <div class="profile-card glass-panel">
      
      <!-- بخش آواتار -->
      <div class="avatar-wrapper">
        <div class="avatar-ring">
          <img src={USER_PROFILE.avatarUrl} alt={USER_PROFILE.nickname} class="avatar-img" />
        </div>
      </div>

      <!-- بخش اطلاعات شخصی -->
      <div class="profile-info">
        <h1>
  {USER_PROFILE.name}
  {USER_PROFILE.nickname ? ` (${USER_PROFILE.nickname})` : ""}
</h1>
        <h2 class="subtitle">{USER_PROFILE.role}</h2>
        
        <div class="bio-text">
          <p>
            سلام! به <strong>BaqiShelf</strong> خوش آمدید. این سایت، گوشه‌ای دنج از اینترنت است که من برای ثبت، نقد و بایگانی تمام تجربیاتم در دنیای سرگرمی ساخته‌ام.
          </p>
          <p>
            از فیلم‌های شاهکار سینما گرفته تا بازی‌های ویدیویی که ساعت‌ها در آن‌ها غرق شده‌ام، و از کتاب‌هایی که جهان‌بینی‌ام را تغییر داده‌اند تا موسیقی‌هایی که با آن‌ها زندگی کرده‌ام؛ همه چیز اینجا با دقت و وسواس ثبت می‌شود.
          </p>
          <p>
            هدف من از ساخت این آرشیو، داشتن یک دیتابیس کاملاً شخصی و مستقل بود تا بتوانم در گذر زمان، سلیقه و خاطراتم را مرور کنم.
          </p>
        </div>

        <!-- آمار سریع (کاملاً داینامیک) -->
        <div class="quick-stats">
          <div class="q-stat"><span>وضعیت:</span> {currentStatus}</div>
          <div class="q-stat"><span>علاقه اصلی:</span> {mainInterest}</div>
          <div class="q-stat"><span>ژانر محبوب:</span> 🌟 {topGenre}</div>
        </div>

        <!-- بخش حمایت مالی (مینیمال و طلایی) -->
        {USER_PROFILE.donateLink && (
          <a href={USER_PROFILE.donateLink} target="_blank" rel="noreferrer" class="donate-box">
            <span class="d-text">{USER_PROFILE.donateText}</span>
          </a>
        )}

        <!-- شبکه‌های اجتماعی (با لوگوهای واقعی SVG و رندر هوشمند) -->
        <div class="social-grid">
          
          {USER_PROFILE.socials.github && (
            <a href={USER_PROFILE.socials.github} target="_blank" class="social-btn github">
              <svg viewBox="0 0 24 24" class="s-icon"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              گیت‌هاب
            </a>
