---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import MusicCard from "../components/MusicCard.astro";
import SearchBar from "../components/SearchBar.astro";
import ViewSwitcher from "../components/ViewSwitcher.astro";

const base = import.meta.env.BASE_URL;

const music = await getCollection("music");

const sortedMusic = [...music].sort(
  (a, b) => b.data.personal_rating - a.data.personal_rating
);
---

<BaseLayout title="موسیقی">
  <h1>موسیقی</h1>

  <SearchBar placeholder="جستجوی موسیقی..." />

  <div class="filters">
    <select id="status-filter">
      <option value="">همه وضعیت‌ها</option>
      <option value="listened">گوش داده شده</option>
      <option value="listening">در حال گوش دادن</option>
      <option value="planned">برنامه گوش دادن</option>
      <option value="dropped">رها شده</option>
    </select>

    <select id="tag-filter">
  <option value="">همه تگ‌ها</option>
  <option value="favorite">Favorite</option>
  <option value="masterpiece">Masterpiece</option>
  <option value="hidden-gem">Hidden Gem</option>
  <option value="Bullshit">Bullshit</option>
</select>

    <select id="sort-filter">
      <option value="rating-desc">امتیاز ↓</option>
      <option value="rating-asc">امتیاز ↑</option>
      <option value="year-desc">سال انتشار ↓</option>
      <option value="year-asc">سال انتشار ↑</option>
      <option value="date-desc">تاریخ گوش دادن ↓</option>
      <option value="date-asc">تاریخ گوش دادن ↑</option>
    </select>
  </div>

  <ViewSwitcher basePath={`${base}music`} />

  <p>تعداد آثار: <span id="item-count">{music.length}</span></p>

  <div id="media-list">
    {sortedMusic.map((item) => (
      <MusicCard music={item} />
    ))}
  </div>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const searchInput = document.getElementById("media-search");
    const statusSelect = document.getElementById("status-filter");
    const tagSelect = document.getElementById("tag-filter");
    const sortSelect = document.getElementById("sort-filter");
    const mediaList = document.getElementById("media-list");
    const countDisplay = document.getElementById("item-count");

    if (!mediaList) return;

    const getCards = () => [...document.querySelectorAll("#media-list .card")];

    const applyFiltersAndSort = () => {
      const query = searchInput?.value.trim().toLowerCase() ?? "";
      const status = statusSelect?.value ?? "";
      const tag = tagSelect?.value ?? "";
      const sortValue = sortSelect?.value ?? "rating-desc";

      let visibleCount = 0;
      const cards = getCards();

      cards.forEach((card) => {
        const title = card.dataset.title?.toLowerCase() ?? "";
        const cardStatus = card.dataset.status ?? "";
        const cardTags = (card.dataset.tags ?? "").split(",");

        let visible = true;

        if (query && !title.includes(query)) visible = false;
        if (status && cardStatus !== status) visible = false;
        if (tag && !cardTags.includes(tag)) visible = false;

        card.style.display = visible ? "" : "none";

        if (visible) visibleCount++;
      });

      if (countDisplay) {
        countDisplay.textContent = visibleCount.toString();
      }

      const visibleCards = cards.filter(
        (card) => card.style.display !== "none"
      );

      visibleCards.sort((a, b) => {
        switch (sortValue) {
          case "rating-desc":
            return Number(b.dataset.rating) - Number(a.dataset.rating);

          case "rating-asc":
            return Number(a.dataset.rating) - Number(b.dataset.rating);

          case "year-desc":
            return Number(b.dataset.year) - Number(a.dataset.year);

          case "year-asc":
            return Number(a.dataset.year) - Number(b.dataset.year);

          case "date-desc":
            return Number(b.dataset.date) - Number(a.dataset.date);

          case "date-asc":
            return Number(a.dataset.date) - Number(b.dataset.date);

          default:
            return 0;
        }
      });

      visibleCards.forEach((card) => mediaList.appendChild(card));
    };

    const handleChange = () =>
      requestAnimationFrame(applyFiltersAndSort);

    searchInput?.addEventListener("input", handleChange);
    statusSelect?.addEventListener("change", handleChange);
    tagSelect?.addEventListener("change", handleChange);
    sortSelect?.addEventListener("change", handleChange);
  });
</script>

<style>
  .filters {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .filters select {
    background: #111;
    color: white;
    border: 1px solid #333;
    padding: 0.6rem;
    border-radius: 8px;
    cursor: pointer;
  }

  #media-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>