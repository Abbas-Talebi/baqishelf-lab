---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import SearchBar from "../components/SearchBar.astro";
import ViewSwitcher from "../components/ViewSwitcher.astro";
import { getStatusLabel } from "../utils/helpers";

const base = import.meta.env.BASE_URL;
const movies = await getCollection("movies");

// تبدیل داده‌ها به JSON برای استفاده در کلاینت
const clientData = JSON.stringify(movies.map(m => ({
  id: m.id,
  title: m.data.title,
  year: m.data.year,
  rating: m.data.personal_rating,
  status: m.data.status,
  statusLabel: getStatusLabel(m.data.status),
  genres: m.data.genres || [],
  tags: m.data.tags || [],
  date: m.data.date_watched ? m.data.date_watched.getTime() : 0,
  cover: m.data.cover ? `${base}covers/${m.data.cover}` : null,
  slug: `${base}movies/${m.id}`
})));
---

<BaseLayout title="فیلم‌ها">
  <h1>🎬 فیلم‌ها</h1>

  <SearchBar placeholder="جستجوی فیلم..." />
  
  <div class="filters">
    <select id="status-filter">
      <option value="">همه وضعیت‌ها</option>
      <option value="watched">تماشا شده</option>
      <option value="watching">در حال تماشا</option>
      <option value="planned">برنامه تماشا</option>
      <option value="dropped">رها شده</option>
    </select>

    <select id="tag-filter">
      <option value="">همه تگ‌ها</option>
      <option value="favorite">Favorite</option>
      <option value="masterpiece">Masterpiece</option>
      <option value="hidden-gem">Hidden Gem</option>
      <option value="Bullshit">Bullshit</option>
    </select>

    <select id="sort-filter">
      <option value="rating-desc">امتیاز ↓</option>
      <option value="rating-asc">امتیاز ↑</option>
      <option value="year-desc">سال انتشار ↓</option>
      <option value="year-asc">سال انتشار ↑</option>
      <option value="date-desc">تاریخ تماشا ↓</option>
      <option value="date-asc">تاریخ تماشا ↑</option>
    </select>
  </div>

  <ViewSwitcher basePath={`${base}movies`} />

  <p class="stats-text">تعداد فیلم‌ها: <strong id="item-count" style="color: #fff;">{movies.length}</strong></p>

  <!-- کانتینر اصلی کارت‌ها -->
  <div id="media-list" class="media-grid"></div>

  <!-- دکمه نمایش بیشتر -->
  <div class="load-more-container">
    <button id="load-more-btn" class="load-more-btn">نمایش بیشتر ↓</button>
    <p id="showing-count" class="showing-count"></p>
  </div>

  <!-- دیتای مخفی -->
  <script id="movies-data" type="application/json" set:html={clientData}></script>

</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const rawData = document.getElementById("movies-data").textContent;
    const allItems = JSON.parse(rawData);
    
    const searchInput = document.getElementById("media-search");
    const statusSelect = document.getElementById("status-filter");
    const tagSelect = document.getElementById("tag-filter");
    const sortSelect = document.getElementById("sort-filter");
    const mediaList = document.getElementById("media-list");
    const countDisplay = document.getElementById("item-count");
    const loadMoreBtn = document.getElementById("load-more-btn");
    const showingCountText = document.getElementById("showing-count");

    const ITEMS_PER_PAGE = 20;
    let currentPage = 1;
    let filteredItems = [];

    // تابع تولید ستاره‌ها
    const renderStars = (rating) => {
      const fullStars = Math.floor(rating);
      const halfStar = rating % 1 >= 0.5;
      const emptyStars = 5 - fullStars - (halfStar ? 1 : 0);
      return `<span class="rating-stars">${"★".repeat(fullStars)}${halfStar ? "½" : ""}${"☆".repeat(emptyStars)}</span>`;
    };

    const applyFiltersAndSort = () => {
      const query = searchInput?.value.trim().toLowerCase() ?? "";
      const status = statusSelect?.value ?? "";
      const tag = tagSelect?.value ?? "";
      const sortValue = sortSelect?.value ?? "rating-desc";

      // 1. فیلتر کردن
      filteredItems = allItems.filter(item => {
        const titleMatch = !query || item.title.toLowerCase().includes(query);
        const statusMatch = !status || item.status === status;
        const tagMatch = !tag || item.tags.includes(tag);
        return titleMatch && statusMatch && tagMatch;
      });

      // 2. مرتب‌سازی
      filteredItems.sort((a, b) => {
        switch (sortValue) {
          case "rating-desc": return b.rating - a.rating;
          case "rating-asc": return a.rating - b.rating;
          case "year-desc": return b.year - a.year;
          case "year-asc": return a.year - b.year;
          case "date-desc": return b.date - a.date;
          case "date-asc": return a.date - b.date;
          default: return 0;
        }
      });

      countDisplay.textContent = filteredItems.length;
      currentPage = 1;
      renderItems();
    };

    const renderItems = () => {
      if (currentPage === 1) mediaList.innerHTML = ''; 
      
      const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
      const endIndex = startIndex + ITEMS_PER_PAGE;
      const itemsToRender = filteredItems.slice(startIndex, endIndex);

      itemsToRender.forEach(item => {
        const card = document.createElement('a');
        card.href = item.slug;
        card.className = 'media-card';
        
        const favBadge = item.tags.includes('favorite') ? `<span class="favorite-badge">★ Favorite</span>` : '';
        const genresHtml = item.genres.length > 0 ? `<p class="genres">${item.genres.join('، ')}</p>` : '';
        const imageHtml = item.cover 
          ? `<img src="${item.cover}" alt="${item.title}" class="cover-img" loading="lazy" decoding="async" />`
          : `<div class="cover-placeholder">🎬</div>`;

        card.innerHTML = `
          ${imageHtml}
          <div class="card-info">
            ${favBadge}
            <h2>${item.title}</h2>
            <div class="rating-wrapper">${renderStars(item.rating)}</div>
            <p class="year">${item.year}</p>
            ${genresHtml}
            <span class="status-badge">${item.statusLabel}</span>
          </div>
        `;
        mediaList.appendChild(card);
      });

      const currentlyShowing = Math.min(currentPage * ITEMS_PER_PAGE, filteredItems.length);
      showingCountText.textContent = `نمایش ${currentlyShowing} از ${filteredItems.length} فیلم`;

      if (currentlyShowing >= filteredItems.length) {
        loadMoreBtn.style.display = 'none';
      } else {
        loadMoreBtn.style.display = 'block';
      }
    };

    searchInput?.addEventListener("input", applyFiltersAndSort);
    statusSelect?.addEventListener("change", applyFiltersAndSort);
    tagSelect?.addEventListener("change", applyFiltersAndSort);
    sortSelect?.addEventListener("change", applyFiltersAndSort);
    
    loadMoreBtn?.addEventListener("click", () => {
      currentPage++;
      renderItems();
    });

    applyFiltersAndSort();
  });
</script>

<style is:global>
  h1 { font-size: 2.5rem; margin-bottom: 2rem; }

  .filters { display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .filters select { background: #111; color: white; border: 1px solid #333; padding: 0.7rem 1rem; border-radius: 10px; cursor: pointer; font-family: inherit; outline: none; }
  .filters select:hover { border-color: #666; }

  .stats-text { color: #888; margin-bottom: 2rem; }

  /* Grid Layout for Cards */
  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.5rem;
  }

  /* Card Styles */
  .media-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.2rem;
    background: #111;
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, border-color 0.2s;
    overflow: hidden;
  }

  .media-card:hover {
    transform: translateY(-4px);
    border-color: #8b5cf6;
  }

  .cover-img {
  width: 180px;
  height: 270px;
  object-fit: cover;
  border-radius: 8px;
  flex-shrink: 0;
  background: #222;
}

  .cover-placeholder {
    width: 120px;
    height: 180px;
    background: #222;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    flex-shrink: 0;
  }

  .card-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-info h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.3rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #fff;
  }

  .rating-wrapper { margin-bottom: 0.5rem; }
  .rating-stars { color: #fbbf24; font-size: 1.1rem; letter-spacing: 2px; }

  .year { margin: 0 0 0.5rem 0; color: #888; font-size: 1rem; }
  .genres { margin: 0 0 1rem 0; color: #aaa; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .favorite-badge {
    display: inline-block;
    align-self: flex-start;
    margin-bottom: 0.5rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: rgba(245, 158, 11, 0.1);
    color: #fbbf24;
    border: 1px solid rgba(245, 158, 11, 0.3);
    font-size: 0.8rem;
    font-weight: bold;
  }

  .status-badge {
    display: inline-block;
    align-self: flex-start;
    padding: 0.3rem 0.8rem;
    background: #222;
    border: 1px solid #444;
    border-radius: 999px;
    font-size: 0.85rem;
    color: #ccc;
  }

  /* Load More Button */
  .load-more-container { text-align: center; margin-top: 3rem; }
  .load-more-btn { background: #8b5cf6; color: #fff; border: none; padding: 1rem 3rem; border-radius: 999px; font-size: 1rem; font-weight: bold; cursor: pointer; transition: background 0.2s; font-family: inherit; }
  .load-more-btn:hover { background: #7c3aed; }
  .showing-count { color: #666; font-size: 0.9rem; margin-top: 1rem; }

  /* Mobile Responsive */
  @media (max-width: 600px) {
    .media-grid { grid-template-columns: 1fr; }
    .media-card { padding: 1rem; gap: 1rem; }
    .cover-img, .cover-placeholder { width: 90px; height: 135px; }
    .card-info h2 { font-size: 1.1rem; white-space: normal; }
  }
</style>