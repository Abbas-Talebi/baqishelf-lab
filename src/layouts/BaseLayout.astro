---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO & Meta Tags -->
    <title>{title} | BaqiShelf</title>
    <meta name="description" content="آرشیو شخصی فیلم، سریال، بازی، کتاب و موسیقی من" />
    <meta name="author" content="Baqi" />
    
    <!-- Open Graph (برای نمایش در تلگرام، توییتر و...) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | BaqiShelf`} />
    <meta property="og:description" content="آرشیو شخصی فیلم، سریال، بازی، کتاب و موسیقی من" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>

<body>
  <Header />
  <main>
    <slot />
  </main>
</body>
</html>