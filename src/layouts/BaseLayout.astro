---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;

// تولید Canonical URL برای جلوگیری از مشکل www و non-www
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// داده‌های ساختاریافته (JSON-LD) برای معرفی شما و سایت به گوگل
const schemaData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "BaqiShelf",
  "url": Astro.site,
  "author": {
    "@type": "Person",
    "name": "Baqi"
  },
  "description": "آرشیو و دیتابیس شخصی فیلم، سریال، بازی، کتاب و موسیقی من."
};
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- ================= SEO & Meta Tags ================= -->
    <title>{title} | BaqiShelf</title>
    
    <!-- توضیحات طولانی‌تر و استاندارد برای گوگل (بین 150 تا 220 کاراکتر) -->
    <meta name="description" content="BaqiShelf یک آرشیو و دیتابیس شخصی است برای ثبت، نقد و بررسی فیلم‌های سینمایی، سریال‌های تلویزیونی، بازی‌های ویدیویی، کتاب‌ها و آلبوم‌های موسیقی که تجربه کرده‌ام." />
    
    <!-- کلمات کلیدی (Keywords) -->
    <meta name="keywords" content="آرشیو فیلم, نقد بازی, معرفی کتاب, لیست سریال, موسیقی, دیتابیس شخصی, BaqiShelf, باقی" />
    <meta name="author" content="Baqi" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- ================= Open Graph (Social Media) ================= -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | BaqiShelf`} />
    <meta property="og:description" content="BaqiShelf یک آرشیو و دیتابیس شخصی است برای ثبت، نقد و بررسی فیلم‌ها، سریال‌ها، بازی‌ها، کتاب‌ها و موسیقی." />
    
    <!-- ================= Favicons ================= -->
    <!-- معرفی دقیق فاوآیکون‌ها برای مرورگرهای مختلف -->
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <link rel="apple-touch-icon" href={`${base}favicon.svg`} />

    <!-- ================= Structured Data (JSON-LD) ================= -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </head>

<body>
  <Header />
  <main>
    <slot />
  </main>
</body>
</html>